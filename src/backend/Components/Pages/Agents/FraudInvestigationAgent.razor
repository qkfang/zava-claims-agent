@page "/agents/fraud-investigation"

<PageTitle>Fraud Investigation Agent — Claims Team in a Day</PageTitle>

<div class="agent-header" style="--accent: #ef4444">
    <a class="back-link" href="/"><span aria-hidden="true">←</span> Back to claims office</a>
    <div class="agent-header-row">
        <div class="agent-header-icon">🛡️</div>
        <div>
            <div class="agent-header-dept">Fraud Investigation</div>
            <h1>Fraud Investigation Agent</h1>
            <div class="agent-header-persona">Felix — Fraud Investigator</div>
            <p class="tagline">Quietly checks every claim for inconsistencies — fairly and explainably.</p>
        </div>
    </div>
</div>

<div class="agent-tab-scope" style="--accent: #ef4444">
    <nav class="agent-tabs" role="tablist" aria-label="Fraud Investigation agent details">
        <button type="button" class="agent-tab active" data-tab="overview" role="tab" aria-selected="true" tabindex="0">Overview</button>
        <button type="button" class="agent-tab" data-tab="try" role="tab" aria-selected="false" tabindex="-1">Try it out</button>
    </nav>

    <div class="agent-tab-panel active" data-panel="overview" role="tabpanel">
    <section class="panel" style="--accent: #ef4444">
        <h2>What this agent does</h2>
        <p>
            Scores the claim for fraud risk, explains every flag in plain English, and
            recommends investigation steps for a human investigator.
        </p>
        <div class="two-col">
            <div>
                <h3>Responsibilities</h3>
                <ul>
                    <li>Build a timeline from emails, form data, and documents.</li>
                    <li>Compare the claim against prior claim history.</li>
                    <li>Run duplicate-receipt and document-tamper checks.</li>
                    <li>Produce an explainable risk score with cited indicators.</li>
                    <li>Recommend next investigation steps — never accuse the customer.</li>
                </ul>
            </div>
            <div>
                <h3>Tools available</h3>
                <ul>
                    <li>Timeline builder</li>
                    <li>Document comparison</li>
                    <li>Duplicate receipt checker</li>
                    <li>Prior claims search</li>
                    <li>Risk scoring model</li>
                </ul>
                <h3>Human approval</h3>
                <p class="approval">
                    Always required before fraud referral, claim delay due to investigation,
                    customer interview, or fraud-based decline.
                </p>
            </div>
        </div>
    </section>

    <section class="panel" style="--accent: #ef4444">
        <h2>How this agent helps with the claim</h2>
        <div class="demo">
            <p>
                Every new claim is quietly checked by Felix's fraud agent in the background. It
                builds a timeline from the email, form, and document timestamps, looks for
                duplicate receipts across the network, and compares the claim against the
                customer's prior history.
            </p>
            <p>
                The output is an explainable risk score with the indicators that drove it. Most
                claims come back green and continue along the standard path with no customer
                friction. Anything elevated is handed to a human fraud investigator with the
                evidence laid out — the agent never makes the call to delay or refer a claim
                on its own.
            </p>
        </div>
    </section>

    </div>

    <div class="agent-tab-panel" data-panel="try" role="tabpanel">
    <section class="panel fraud-panel" style="--accent: #ef4444">
        <h2>Try It Out — Fraud Investigation Demo</h2>
        <p class="muted fraud-help">
            Pick a claim that the Claims Intake demo has already lodged, then engage
            Felix's fraud agent to score the case for fraud risk and recommend the
            next investigation steps. The demo runs live against the
            <code>/fraud/*</code> endpoints in this app.
        </p>

        <!-- Step 1 — pick a claim -->
        <div class="fraud-step" data-step="1">
            <div class="fraud-step-head">
                <span class="fraud-step-num">1</span>
                <h3>Pick a claim to investigate</h3>
            </div>
            <p class="muted">
                The dropdown lists every claim minted by the
                <a href="/agents/claims-intake">Claims Intake</a> Try It Out tab.
                Run that demo first if the list is empty.
            </p>
            <div class="fraud-claim-row">
                <select id="fraud-claim-select" class="fraud-select">
                    <option value="">— Loading claims… —</option>
                </select>
                <button type="button" id="fraud-refresh-btn" class="fraud-secondary" title="Reload claims">↻</button>
            </div>
            <div class="fraud-empty" id="fraud-empty" hidden>
                No claims found in memory. Lodge one from the
                <a href="/agents/claims-intake">Claims Intake</a> Try It Out tab first.
            </div>
        </div>

        <!-- Step 2 — claim details -->
        <div class="fraud-step" data-step="2" id="fraud-claim-step" hidden>
            <div class="fraud-step-head">
                <span class="fraud-step-num">2</span>
                <h3>Review the captured claim</h3>
            </div>
            <div class="fraud-claim-grid" id="fraud-claim-details"></div>
        </div>

        <!-- Step 2b — case documents -->
        <div class="fraud-step" data-step="2b" id="fraud-docs-step" hidden>
            <div class="fraud-step-head">
                <span class="fraud-step-num">2b</span>
                <h3>Scan documents on the case</h3>
            </div>
            <p class="muted">
                These are the ID and scan documents on the claim file. Felix's
                fraud agent will run each selected document through Azure
                Content Understanding, score it as <em>legit / suspicious / fake</em>,
                and explain every authenticity check it ran. Tick or untick to
                control which documents are reviewed, or pick extra samples
                from the popover.
            </p>
            <div class="fraud-docs-row">
                <div id="fraud-case-docs" class="fraud-doc-grid">
                    <div class="fraud-doc-empty muted">Loading case documents…</div>
                </div>
                <span id="fraud-sample-host"></span>
            </div>
        </div>

        <!-- Step 3 — engage agent -->
        <div class="fraud-step" data-step="3" id="fraud-process-step" hidden>
            <div class="fraud-step-head">
                <span class="fraud-step-num">3</span>
                <h3>Engage Fraud Investigation Agent</h3>
            </div>
            <p class="muted">
                Felix builds a timeline from the captured claim, runs fraud
                indicators &amp; rules, cross-checks against history, and produces
                a risk summary with recommended next actions for a human investigator.
            </p>
            <button id="fraud-process-btn" type="button">Run fraud investigation</button>
            <div id="fraud-process-status" class="fraud-status" hidden></div>

            <div class="engage-tabs-scope" data-engage-role="fraud">
                <div class="engage-tabs" role="tablist">
                    <button type="button" class="engage-tab-btn active" data-engage-tab="prompt">Agent Prompt &amp; Tools</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="input">Agent Input</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="output">Raw Output</button>
                </div>

                <div class="engage-tab-panel active" data-engage-tab="prompt">
                    <div class="engage-info-block">
                        <h4>Agent metadata</h4>
                        <div class="engage-info-meta engage-meta"></div>
                    </div>
                    <div class="engage-info-block">
                        <h4>System prompt</h4>
                        <pre class="engage-pre engage-prompt-body">Loading…</pre>
                    </div>
                    <div class="engage-info-block">
                        <h4>Tools available</h4>
                        <ul class="engage-tools-list"><li class="engage-empty">Loading…</li></ul>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="input">
                    <div class="engage-info-block">
                        <h4>Prompt sent to the agent</h4>
                        <pre class="engage-pre engage-input-body engage-empty">Engage the agent to capture the input that was sent.</pre>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="output">
                    <div class="engage-info-block">
                        <h4>Raw agent output (text, citations, every output item including tool / function calls)</h4>
                        <div class="json-viewer engage-output-body"><div class="engage-empty">Engage the agent to see the full raw response.</div></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 4 — output -->
        <div class="fraud-step" data-step="4" id="fraud-output-step" hidden>
            <div class="fraud-step-head">
                <span class="fraud-step-num">4</span>
                <h3>Risk summary &amp; recommended actions</h3>
            </div>

            <div class="fraud-risk-card">
                <div class="fraud-risk-head">
                    <span class="fraud-risk-label">Fraud Risk Score</span>
                    <span class="fraud-risk-pill" id="fraud-risk-pill"></span>
                    <span class="fraud-risk-num" id="fraud-risk-num"></span>
                </div>
                <p id="fraud-risk-summary" class="fraud-risk-summary"></p>
            </div>

            <div class="fraud-output-grid">
                <div class="fraud-output-block">
                    <div class="fraud-output-label">Risk indicators</div>
                    <ul id="fraud-indicators" class="fraud-list"></ul>
                </div>
                <div class="fraud-output-block">
                    <div class="fraud-output-label">Timeline inconsistencies</div>
                    <ul id="fraud-inconsistencies" class="fraud-list"></ul>
                </div>
                <div class="fraud-output-block">
                    <div class="fraud-output-label">Investigation action plan</div>
                    <ol id="fraud-actions" class="fraud-list"></ol>
                </div>
                <div class="fraud-output-block">
                    <div class="fraud-output-label">Human approval required</div>
                    <p id="fraud-approval" class="fraud-approval-text"></p>
                </div>
            </div>

            <div id="fraud-doc-output" class="fraud-doc-output" hidden>
                <div class="fraud-output-label">Document authenticity</div>
                <p class="muted fraud-doc-output-hint" id="fraud-doc-output-hint"></p>
                <div id="fraud-doc-cards" class="fraud-doc-cards"></div>
            </div>

            <div id="fraud-agent-notes" class="fraud-notes" hidden>
                <div class="fraud-notes-label">Foundry agent narrative</div>
                <div id="fraud-agent-notes-body" class="agent-md"></div>
            </div>
        </div>
    </section>
    </div>
</div>

<style>
    .fraud-panel { --fraud-accent: #ef4444; }
    .fraud-help { margin-bottom: 0.9rem; }
    .fraud-help code { background: rgba(239, 68, 68, 0.12); padding: 1px 6px; border-radius: 4px; font-size: 0.85rem; }

    .fraud-step {
        border: 1px solid rgba(120, 150, 200, 0.18);
        background: rgba(15, 22, 38, 0.4);
        border-radius: 12px;
        padding: 0.95rem 1.1rem 1rem 1.1rem;
        margin-top: 0.9rem;
    }
    .fraud-step-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.3rem; }
    .fraud-step-head h3 { margin: 0; color: #fff; font-size: 1rem; }
    .fraud-step-num {
        display: inline-grid; place-items: center;
        width: 1.55rem; height: 1.55rem;
        border-radius: 50%;
        background: color-mix(in srgb, var(--fraud-accent) 22%, rgba(20, 28, 46, 0.7));
        border: 1px solid color-mix(in srgb, var(--fraud-accent) 55%, transparent);
        color: var(--fraud-accent);
        font-size: 0.78rem; font-weight: 700;
    }
    .fraud-step .muted { color: var(--zava-muted, #97a3b6); font-size: 0.9rem; margin: 0.35rem 0 0.7rem 0; }

    .fraud-claim-row { display: flex; gap: 0.5rem; align-items: center; }
    .fraud-select {
        flex: 1;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.22);
        border-radius: 6px;
        color: #fff;
        font-size: 0.9rem;
        padding: 0.55rem 0.7rem;
    }
    .fraud-select:focus {
        outline: none;
        border-color: var(--fraud-accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--fraud-accent) 25%, transparent);
    }
    .fraud-secondary {
        background: transparent;
        color: rgba(238, 242, 247, 0.86);
        border: 1px solid rgba(120, 150, 200, 0.32);
        border-radius: 6px;
        padding: 0.45rem 0.75rem;
        font-size: 0.95rem;
        cursor: pointer;
    }
    .fraud-secondary:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }
    .fraud-empty {
        margin-top: 0.6rem;
        padding: 0.6rem 0.8rem;
        background: rgba(245, 158, 11, 0.10);
        border: 1px solid rgba(245, 158, 11, 0.35);
        border-radius: 8px;
        color: #fcd34d;
        font-size: 0.86rem;
    }
    .fraud-empty a { color: #fde68a; }

    .fraud-claim-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.45rem 0.85rem;
        font-size: 0.86rem;
        color: rgba(238, 242, 247, 0.86);
    }
    @@media (max-width: 820px) { .fraud-claim-grid { grid-template-columns: 1fr; } }
    .fraud-claim-grid .k {
        display: inline-block; min-width: 110px;
        color: var(--zava-muted, #97a3b6); font-weight: 600;
        text-transform: uppercase; font-size: 0.66rem; letter-spacing: 0.08em;
        margin-right: 0.5rem;
    }
    .fraud-claim-grid .span-2 { grid-column: span 2; }
    @@media (max-width: 820px) { .fraud-claim-grid .span-2 { grid-column: span 1; } }

    #fraud-process-btn {
        background: var(--fraud-accent);
        color: #2a0606;
        border: none;
        border-radius: 8px;
        padding: 0.55rem 1.1rem;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 0.35rem;
    }
    #fraud-process-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .fraud-status { margin-top: 0.6rem; font-size: 0.88rem; color: rgba(238, 242, 247, 0.88); }
    .fraud-status.error { color: #fca5a5; }
    .fraud-status .spinner {
        display: inline-block; width: 12px; height: 12px;
        border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
        border-radius: 50%; margin-right: 6px; vertical-align: middle;
        animation: fraud-spin 0.7s linear infinite;
    }
    @@keyframes fraud-spin { to { transform: rotate(360deg); } }

    .fraud-risk-card {
        background: color-mix(in srgb, var(--fraud-accent) 10%, rgba(15, 22, 38, 0.7));
        border: 1px solid color-mix(in srgb, var(--fraud-accent) 35%, transparent);
        border-radius: 10px;
        padding: 0.8rem 1rem;
        margin-top: 0.4rem;
    }
    .fraud-risk-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.35rem; }
    .fraud-risk-label { color: #fff; font-weight: 700; font-size: 0.9rem; }
    .fraud-risk-pill {
        padding: 0.18rem 0.7rem;
        border-radius: 999px;
        font-size: 0.72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
    }
    .fraud-risk-pill.high   { background: rgba(239, 68, 68, 0.18); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.4); }
    .fraud-risk-pill.medium { background: rgba(245, 158, 11, 0.18); color: #fcd34d; border: 1px solid rgba(245, 158, 11, 0.4); }
    .fraud-risk-pill.low    { background: rgba(34, 197, 94, 0.16); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.4); }
    .fraud-risk-num {
        margin-left: auto;
        color: rgba(238, 242, 247, 0.86);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.85rem;
    }
    .fraud-risk-summary { margin: 0; color: rgba(238, 242, 247, 0.88); font-size: 0.88rem; line-height: 1.45; }

    .fraud-output-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.7rem;
        margin-top: 0.7rem;
    }
    @@media (max-width: 820px) { .fraud-output-grid { grid-template-columns: 1fr; } }
    .fraud-output-block {
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 8px;
        padding: 0.65rem 0.85rem;
    }
    .fraud-output-label {
        font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.12em;
        color: var(--zava-muted, #97a3b6); font-weight: 700; margin-bottom: 0.4rem;
    }
    .fraud-list { margin: 0; padding-left: 1.1rem; color: rgba(238, 242, 247, 0.88); font-size: 0.86rem; line-height: 1.5; }
    .fraud-list li { margin: 0.2rem 0; }
    .fraud-approval-text { margin: 0; color: rgba(238, 242, 247, 0.88); font-size: 0.88rem; line-height: 1.45; }

    .fraud-notes {
        margin-top: 0.7rem;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 8px;
        padding: 0.7rem 0.85rem;
    }
    .fraud-notes-label {
        font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.12em;
        color: var(--zava-muted, #97a3b6); font-weight: 700; margin-bottom: 0.35rem;
    }
    .fraud-notes pre {
        color: rgba(238, 242, 247, 0.86);
        font-size: 0.82rem;
        line-height: 1.5;
        white-space: pre-wrap;
        margin: 0;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    /* Step 2b — case documents */
    .fraud-docs-row { display: flex; gap: 0.7rem; align-items: flex-start; flex-wrap: wrap; }
    .fraud-doc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
        gap: 0.55rem;
        flex: 1;
        min-width: 260px;
    }
    .fraud-doc-empty { padding: 0.55rem; }
    .fraud-doc-tile {
        position: relative;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.22);
        border-radius: 8px;
        padding: 0.55rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }
    .fraud-doc-tile.selected {
        border-color: var(--fraud-accent);
        box-shadow: 0 0 0 1px color-mix(in srgb, var(--fraud-accent) 40%, transparent);
    }
    .fraud-doc-tile img {
        width: 100%;
        height: 100px;
        object-fit: cover;
        border-radius: 5px;
        background: #0a101c;
        cursor: zoom-in;
    }
    .fraud-doc-tile .fraud-doc-title {
        font-size: 0.78rem;
        color: rgba(238, 242, 247, 0.92);
        line-height: 1.25;
    }
    .fraud-doc-tile .fraud-doc-kind {
        font-size: 0.66rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--zava-muted, #97a3b6);
    }
    .fraud-doc-tile .fraud-doc-toggle {
        display: flex; align-items: center; gap: 0.35rem;
        font-size: 0.78rem;
        color: rgba(238, 242, 247, 0.86);
    }
    .fraud-doc-tile.removable .fraud-doc-remove {
        position: absolute; top: 4px; right: 6px;
        background: transparent; color: rgba(238, 242, 247, 0.65);
        border: none; cursor: pointer; font-size: 0.85rem; padding: 2px 4px;
    }
    .fraud-doc-tile.removable .fraud-doc-remove:hover { color: #fca5a5; }

    /* Sample-doc popover trigger sits inside the docs row */
    #fraud-sample-host { align-self: stretch; display: flex; align-items: flex-start; }

    /* Step 4 — per-document authenticity card */
    .fraud-doc-output { margin-top: 0.9rem; }
    .fraud-doc-output-hint { margin: 0 0 0.5rem 0; font-size: 0.82rem; }
    .fraud-doc-cards { display: grid; gap: 0.7rem; }
    .fraud-doc-card {
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 10px;
        padding: 0.7rem 0.85rem;
        display: grid;
        grid-template-columns: 110px 1fr;
        gap: 0.7rem;
    }
    @@media (max-width: 720px) { .fraud-doc-card { grid-template-columns: 1fr; } }
    .fraud-doc-card img {
        width: 100%; max-height: 130px; object-fit: cover;
        border-radius: 6px; background: #0a101c; cursor: zoom-in;
    }
    .fraud-doc-card-head { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .fraud-doc-card-title { color: #fff; font-weight: 600; font-size: 0.92rem; }
    .fraud-doc-card-kind {
        font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.1em;
        color: var(--zava-muted, #97a3b6);
    }
    .fraud-doc-verdict {
        padding: 0.16rem 0.62rem;
        border-radius: 999px;
        font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
    }
    .fraud-doc-verdict.legit      { background: rgba(34, 197, 94, 0.16); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.4); }
    .fraud-doc-verdict.suspicious { background: rgba(245, 158, 11, 0.18); color: #fcd34d; border: 1px solid rgba(245, 158, 11, 0.4); }
    .fraud-doc-verdict.fake       { background: rgba(239, 68, 68, 0.18); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.4); }
    .fraud-doc-source {
        font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.1em;
        color: var(--zava-muted, #97a3b6); margin-left: auto;
    }
    .fraud-doc-section-label {
        font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.12em;
        color: var(--zava-muted, #97a3b6); font-weight: 700; margin: 0.55rem 0 0.25rem 0;
    }
    .fraud-doc-reasons { margin: 0; padding-left: 1.05rem; font-size: 0.84rem; line-height: 1.45; color: rgba(238, 242, 247, 0.88); }
    .fraud-doc-reasons li { margin: 0.18rem 0; }
    .fraud-doc-checks { list-style: none; margin: 0; padding: 0; font-size: 0.84rem; line-height: 1.45; color: rgba(238, 242, 247, 0.88); }
    .fraud-doc-checks li { display: flex; gap: 0.45rem; align-items: flex-start; padding: 0.15rem 0; }
    .fraud-doc-checks .check-icon { width: 1rem; flex: 0 0 1rem; font-weight: 700; }
    .fraud-doc-checks .check-icon.pass { color: #86efac; }
    .fraud-doc-checks .check-icon.fail { color: #fca5a5; }
    .fraud-doc-checks .check-icon.warn { color: #fcd34d; }
    .fraud-doc-checks .check-icon.na   { color: #94a3b8; }
    .fraud-doc-checks .check-name { font-weight: 600; color: rgba(238, 242, 247, 0.94); }
    .fraud-doc-checks .check-detail { color: rgba(238, 242, 247, 0.78); }
    .fraud-doc-cu {
        margin-top: 0.5rem;
        background: rgba(15, 22, 38, 0.6);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 6px;
    }
    .fraud-doc-cu summary {
        cursor: pointer; padding: 0.35rem 0.55rem; font-size: 0.78rem;
        color: var(--zava-muted, #97a3b6);
    }
    .fraud-doc-cu pre {
        margin: 0; padding: 0.55rem 0.7rem;
        font-size: 0.78rem; line-height: 1.45;
        color: rgba(238, 242, 247, 0.86);
        white-space: pre-wrap; word-break: break-word;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        max-height: 240px; overflow: auto;
    }

    /* Lightweight reusable lightbox shared with the Notice pages */
    .fraud-lightbox {
        position: fixed; inset: 0;
        background: rgba(10, 16, 28, 0.85);
        display: none; align-items: center; justify-content: center;
        z-index: 9000; padding: 2rem;
    }
    .fraud-lightbox.open { display: flex; }
    .fraud-lightbox img { max-width: 96vw; max-height: 92vh; border-radius: 8px; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
    .fraud-lightbox .fraud-lightbox-close {
        position: absolute; top: 14px; right: 18px;
        background: transparent; color: #fff;
        border: none; font-size: 2rem; cursor: pointer;
    }

    /* Sample-docs popover (scoped so it doesn't fight the global Notice CSS) */
    .fraud-sample-trigger {
        display: inline-block; padding: 0.45rem 0.7rem;
        background: rgba(239, 68, 68, 0.12);
        border: 1px solid rgba(239, 68, 68, 0.4);
        border-radius: 6px;
        color: #fca5a5; font-size: 0.85rem; cursor: pointer;
        white-space: nowrap;
    }
    .fraud-sample-trigger:hover { background: rgba(239, 68, 68, 0.18); }
    .fraud-sample-popover {
        position: absolute;
        margin-top: 6px;
        background: #0f172a;
        border: 1px solid rgba(120, 150, 200, 0.32);
        border-radius: 10px;
        padding: 0.7rem;
        width: 380px;
        box-shadow: 0 18px 38px rgba(0, 0, 0, 0.45);
        z-index: 80;
        display: none;
    }
    .fraud-sample-popover.open { display: block; }
    .fraud-sample-popover .fraud-sample-grid {
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.45rem;
        max-height: 380px; overflow: auto;
    }
    .fraud-sample-popover .fraud-sample-tile {
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 8px;
        padding: 0.4rem;
        display: flex; flex-direction: column; gap: 0.3rem;
    }
    .fraud-sample-popover .fraud-sample-tile img {
        width: 100%; height: 80px; object-fit: cover; border-radius: 5px; background: #0a101c; cursor: zoom-in;
    }
    .fraud-sample-popover .fraud-sample-tile .fraud-sample-label {
        font-size: 0.74rem; color: rgba(238, 242, 247, 0.92); line-height: 1.25;
    }
    .fraud-sample-popover .fraud-sample-tile .fraud-sample-add {
        background: var(--fraud-accent); color: #2a0606;
        border: none; border-radius: 5px;
        padding: 0.3rem 0.5rem; font-size: 0.78rem; font-weight: 700;
        cursor: pointer;
    }
    .fraud-sample-popover .fraud-sample-tile .fraud-sample-add:disabled { opacity: 0.4; cursor: not-allowed; }
</style>

<script>
    (function () {
        function init() {
        const root = document.querySelector('.fraud-panel');
        if (!root || root.dataset.wired === '1') return;
        root.dataset.wired = '1';

        const $ = sel => root.querySelector(sel);
        const selectEl = $('#fraud-claim-select');
        const refreshBtn = $('#fraud-refresh-btn');
        const emptyEl = $('#fraud-empty');
        const claimStep = $('#fraud-claim-step');
        const claimDetails = $('#fraud-claim-details');
        const docsStep = $('#fraud-docs-step');
        const docsGrid = $('#fraud-case-docs');
        const sampleHost = $('#fraud-sample-host');
        const processStep = $('#fraud-process-step');
        const processBtn = $('#fraud-process-btn');
        const processStatus = $('#fraud-process-status');
        const outputStep = $('#fraud-output-step');
        const riskPill = $('#fraud-risk-pill');
        const riskNum = $('#fraud-risk-num');
        const riskSummary = $('#fraud-risk-summary');
        const indicatorsEl = $('#fraud-indicators');
        const inconsistenciesEl = $('#fraud-inconsistencies');
        const actionsEl = $('#fraud-actions');
        const approvalEl = $('#fraud-approval');
        const agentNotesEl = $('#fraud-agent-notes');
        const agentNotesBody = $('#fraud-agent-notes-body');
        const docOutputEl = $('#fraud-doc-output');
        const docOutputHint = $('#fraud-doc-output-hint');
        const docCardsEl = $('#fraud-doc-cards');

        let claims = [];
        let selectedClaim = null;
        // documents currently attached to the selected claim
        // (id -> { id, label, kind, src, selected, removable })
        let caseDocs = new Map();
        // full sample manifest, lazy-loaded once
        let sampleManifest = null;

        function escapeHtml(s) {
            return String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
        }

        function row(k, v, span) {
            const cls = span ? ' span-2' : '';
            return `<div class="${cls.trim()}"><span class="k">${escapeHtml(k)}</span><span>${escapeHtml(v || '—')}</span></div>`;
        }

        function renderClaim(c) {
            claimDetails.innerHTML =
                row('Claim #', c.claimNumber) +
                row('Created', c.createdAt) +
                row('Customer', c.customerName) +
                row('Policy', c.policyNumber) +
                row('Claim type', c.claimType) +
                row('Urgency', c.urgency) +
                row('Incident date', c.incidentDate) +
                row('Estimated loss', c.estimatedLoss) +
                row('Location', c.incidentLocation, true) +
                row('Description', c.incidentDescription, true);
        }

        // ── Lightbox (shared between case docs and sample popover) ──
        function ensureLightbox() {
            let lb = document.getElementById('fraud-lightbox');
            if (lb) return lb;
            lb = document.createElement('div');
            lb.id = 'fraud-lightbox';
            lb.className = 'fraud-lightbox';
            lb.innerHTML = '<button class="fraud-lightbox-close" type="button" aria-label="Close">&times;</button><img alt="" />';
            document.body.appendChild(lb);
            lb.addEventListener('click', e => {
                if (e.target === lb || e.target.classList.contains('fraud-lightbox-close')) {
                    lb.classList.remove('open');
                }
            });
            return lb;
        }
        function openLightbox(src) {
            const lb = ensureLightbox();
            lb.querySelector('img').src = src;
            lb.classList.add('open');
        }

        // ── Case-document grid ────────────────────────────────────
        function renderCaseDocs() {
            if (caseDocs.size === 0) {
                docsGrid.innerHTML = '<div class="fraud-doc-empty muted">No scan documents on this case yet — add one from the popover →</div>';
                return;
            }
            const tiles = [];
            for (const d of caseDocs.values()) {
                tiles.push(`
                    <div class="fraud-doc-tile ${d.selected ? 'selected' : ''} ${d.removable ? 'removable' : ''}" data-doc-id="${escapeHtml(d.id)}">
                        ${d.removable ? '<button type="button" class="fraud-doc-remove" title="Remove from case" aria-label="Remove">✕</button>' : ''}
                        <img src="${escapeHtml(d.src)}" alt="${escapeHtml(d.label)}" loading="lazy" />
                        <div class="fraud-doc-kind">${escapeHtml(d.kind)}</div>
                        <div class="fraud-doc-title">${escapeHtml(d.label)}</div>
                        <label class="fraud-doc-toggle">
                            <input type="checkbox" ${d.selected ? 'checked' : ''} />
                            <span>Include in review</span>
                        </label>
                    </div>`);
            }
            docsGrid.innerHTML = tiles.join('');
            docsGrid.querySelectorAll('.fraud-doc-tile').forEach(tile => {
                const id = tile.dataset.docId;
                tile.querySelector('img').addEventListener('click', () => openLightbox(tile.querySelector('img').src));
                const cb = tile.querySelector('input[type="checkbox"]');
                cb.addEventListener('change', () => {
                    const d = caseDocs.get(id);
                    if (d) { d.selected = cb.checked; tile.classList.toggle('selected', d.selected); }
                });
                const removeBtn = tile.querySelector('.fraud-doc-remove');
                if (removeBtn) {
                    removeBtn.addEventListener('click', () => {
                        caseDocs.delete(id);
                        renderCaseDocs();
                        renderSamplePopover();
                    });
                }
            });
        }

        async function loadCaseDocs(claimNumber) {
            docsGrid.innerHTML = '<div class="fraud-doc-empty muted">Loading case documents…</div>';
            caseDocs = new Map();
            try {
                const res = await fetch(`/fraud/claims/${encodeURIComponent(claimNumber)}/documents`);
                if (res.ok) {
                    const docs = await res.json();
                    docs.forEach(d => caseDocs.set(d.id, { ...d, selected: true, removable: false }));
                }
            } catch (err) {
                console.warn('Fraud case docs load failed', err);
            }
            renderCaseDocs();
            renderSamplePopover();
        }

        // ── Sample-doc popover (own mini implementation, scoped so it
        //    doesn't collide with the Notice pages' SAMPLE_DOCS list) ──
        async function ensureSampleManifest() {
            if (sampleManifest) return sampleManifest;
            try {
                const res = await fetch('/fraud/samples');
                sampleManifest = res.ok ? await res.json() : [];
            } catch {
                sampleManifest = [];
            }
            return sampleManifest;
        }

        function renderSamplePopover() {
            sampleHost.innerHTML = `
                <button type="button" class="fraud-sample-trigger" id="fraud-sample-trigger">📎 Add sample docs</button>
                <div class="fraud-sample-popover" id="fraud-sample-popover" role="dialog" aria-label="Sample documents">
                    <div class="sample-docs-title" style="font-weight:600; color:#fff; margin-bottom:4px;">Sample Documents</div>
                    <div class="sample-docs-hint" style="font-size:0.76rem; color:#97a3b6; margin-bottom:8px;">
                        Click an image to preview, or "Add" to attach it to this case.
                    </div>
                    <div class="fraud-sample-grid" id="fraud-sample-grid">
                        <div class="muted" style="padding:0.4rem;">Loading samples…</div>
                    </div>
                </div>`;
            const trigger = sampleHost.querySelector('#fraud-sample-trigger');
            const popover = sampleHost.querySelector('#fraud-sample-popover');
            const grid = sampleHost.querySelector('#fraud-sample-grid');

            // Position the popover relative to the trigger.
            sampleHost.style.position = 'relative';

            function close() { popover.classList.remove('open'); }
            trigger.addEventListener('click', async () => {
                const willOpen = !popover.classList.contains('open');
                document.querySelectorAll('.fraud-sample-popover.open').forEach(p => p.classList.remove('open'));
                if (!willOpen) return;
                popover.classList.add('open');
                const samples = await ensureSampleManifest();
                if (!samples.length) {
                    grid.innerHTML = '<div class="muted" style="padding:0.4rem;">No samples available.</div>';
                    return;
                }
                grid.innerHTML = samples.map(s => {
                    const already = caseDocs.has(s.id);
                    return `
                        <div class="fraud-sample-tile" data-sample-id="${escapeHtml(s.id)}">
                            <img src="${escapeHtml(s.src)}" alt="${escapeHtml(s.label)}" loading="lazy" />
                            <div class="fraud-sample-label">${escapeHtml(s.label)}</div>
                            <button type="button" class="fraud-sample-add" ${already ? 'disabled' : ''}>${already ? 'Attached' : 'Add'}</button>
                        </div>`;
                }).join('');
                grid.querySelectorAll('.fraud-sample-tile').forEach(tile => {
                    const id = tile.dataset.sampleId;
                    const sample = samples.find(s => s.id === id);
                    tile.querySelector('img').addEventListener('click', () => openLightbox(sample.src));
                    tile.querySelector('.fraud-sample-add').addEventListener('click', () => {
                        if (!sample || caseDocs.has(sample.id)) return;
                        caseDocs.set(sample.id, {
                            id: sample.id, label: sample.label, kind: sample.kind, src: sample.src,
                            selected: true, removable: true,
                        });
                        renderCaseDocs();
                        renderSamplePopover();
                    });
                });
            });

            document.addEventListener('click', e => {
                if (!sampleHost.contains(e.target)) close();
            }, { capture: true, once: true });
            document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); }, { once: true });
        }

        function selectedDocumentIds() {
            return Array.from(caseDocs.values()).filter(d => d.selected).map(d => d.id);
        }

        // ── Render per-document authenticity output ──
        function checkIcon(status) {
            switch ((status || '').toLowerCase()) {
                case 'pass': return '<span class="check-icon pass">✓</span>';
                case 'fail': return '<span class="check-icon fail">✗</span>';
                case 'warn': return '<span class="check-icon warn">⚠</span>';
                default:     return '<span class="check-icon na">–</span>';
            }
        }

        function renderDocCards(documents, cuConfigured) {
            if (!documents || !documents.length) {
                docOutputEl.hidden = true;
                docCardsEl.innerHTML = '';
                return;
            }
            docOutputEl.hidden = false;
            docOutputHint.textContent = cuConfigured
                ? `Each document was processed through Azure Content Understanding and the deterministic checks layer.`
                : `Content Understanding is not configured — the checks layer ran against manifest expectations only.`;
            docCardsEl.innerHTML = documents.map((d, idx) => {
                const verdict = (d.verdict || 'suspicious').toLowerCase();
                const reasons = (d.failureReasons || []);
                const checks = (d.checks || []);
                const reasonsHtml = reasons.length
                    ? `<ul class="fraud-doc-reasons">${reasons.map(r => `<li>${escapeHtml(r)}</li>`).join('')}</ul>`
                    : `<p class="muted" style="margin:0; font-size:0.84rem;">No failure reasons — every check passed.</p>`;
                const checksHtml = `<ul class="fraud-doc-checks">${checks.map(c => `
                    <li>${checkIcon(c.status)}<div><div class="check-name">${escapeHtml(c.name)}</div><div class="check-detail">${escapeHtml(c.detail)}</div></div></li>`).join('')}</ul>`;
                const cuBlock = d.cuMarkdown
                    ? `<details class="fraud-doc-cu"><summary>Content Understanding output (markdown)</summary><pre>${escapeHtml(d.cuMarkdown)}</pre></details>`
                    : '';
                return `
                    <div class="fraud-doc-card" data-doc-id="${escapeHtml(d.id)}">
                        <div><img src="${escapeHtml(d.src)}" alt="${escapeHtml(d.label)}" loading="lazy" /></div>
                        <div>
                            <div class="fraud-doc-card-head">
                                <span class="fraud-doc-card-title">Document #${idx + 1} — ${escapeHtml(d.label)}</span>
                                <span class="fraud-doc-verdict ${verdict}">${escapeHtml(verdict)}</span>
                                <span class="fraud-doc-card-kind">${escapeHtml(d.kind)}</span>
                                <span class="fraud-doc-source">${escapeHtml(d.source || '')}</span>
                            </div>
                            <div class="fraud-doc-section-label">Why this verdict</div>
                            ${reasonsHtml}
                            <div class="fraud-doc-section-label">Checks performed</div>
                            ${checksHtml}
                            ${cuBlock}
                        </div>
                    </div>`;
            }).join('');
            docCardsEl.querySelectorAll('.fraud-doc-card img').forEach(img => {
                img.addEventListener('click', () => openLightbox(img.src));
            });
        }

        async function loadClaims(preserveSelection) {
            const previous = preserveSelection ? selectEl.value : null;
            selectEl.innerHTML = '<option value="">— Loading claims… —</option>';
            try {
                const res = await fetch('/fraud/claims');
                if (!res.ok) throw new Error('HTTP ' + res.status);
                claims = await res.json();
                if (!claims.length) {
                    selectEl.innerHTML = '<option value="">— No claims yet —</option>';
                    emptyEl.hidden = false;
                    claimStep.hidden = true;
                    docsStep.hidden = true;
                    processStep.hidden = true;
                    outputStep.hidden = true;
                    return;
                }
                emptyEl.hidden = true;
                selectEl.innerHTML =
                    '<option value="">— Select a claim —</option>' +
                    claims.map(c => `<option value="${escapeHtml(c.claimNumber)}">${escapeHtml(c.claimNumber)} — ${escapeHtml(c.customerName)} (${escapeHtml(c.claimType)})</option>`).join('');
                if (previous && claims.some(c => c.claimNumber === previous)) {
                    selectEl.value = previous;
                    selectClaim(previous);
                }
            } catch (err) {
                selectEl.innerHTML = '<option value="">— Failed to load —</option>';
                emptyEl.hidden = false;
                emptyEl.textContent = 'Failed to load claims: ' + err.message;
            }
        }

        function selectClaim(claimNumber) {
            selectedClaim = claims.find(c => c.claimNumber === claimNumber) || null;
            outputStep.hidden = true;
            processStatus.hidden = true;
            docOutputEl.hidden = true;
            if (!selectedClaim) {
                claimStep.hidden = true;
                docsStep.hidden = true;
                processStep.hidden = true;
                return;
            }
            renderClaim(selectedClaim);
            claimStep.hidden = false;
            docsStep.hidden = false;
            processStep.hidden = false;
            processBtn.disabled = false;
            loadCaseDocs(selectedClaim.claimNumber);
        }

        async function processClaim() {
            if (!selectedClaim) return;
            processBtn.disabled = true;
            processStatus.hidden = false;
            processStatus.className = 'fraud-status';
            processStatus.innerHTML = '<span class="spinner"></span>Engaging Fraud Investigation Agent…';
            outputStep.hidden = true;

            try {
                const data = await window.zcAgentStream({
                    url: '/fraud/process',
                    body: {
                        claimNumber: selectedClaim.claimNumber,
                        documentIds: selectedDocumentIds(),
                    },
                    onDelta: (_chunk, fullText) => {
                        agentNotesEl.hidden = false;
                        agentNotesBody.classList.add('agent-md-streaming');
                        agentNotesBody.textContent = fullText;
                    },
                    onError: (msg) => {
                        processStatus.className = 'fraud-status error';
                        processStatus.textContent = 'Agent error: ' + msg;
                    }
                });
                if (!data) throw new Error('No response from agent');

                processStatus.textContent = data.agentConfigured
                    ? 'Fraud Investigation Agent completed the review.'
                    : 'Reviewed (Foundry agent not configured — using deterministic demo analysis).';

                const level = (data.riskLevel || 'Medium').toString();
                riskPill.textContent = level;
                riskPill.className = 'fraud-risk-pill ' + level.toLowerCase();
                riskNum.textContent = (typeof data.riskScore === 'number') ? `Score: ${data.riskScore}/100` : '';
                riskSummary.textContent = data.riskSummary || '';

                indicatorsEl.innerHTML = (data.indicators || []).map(i => `<li>${escapeHtml(i)}</li>`).join('') || '<li class="muted">None detected.</li>';
                inconsistenciesEl.innerHTML = (data.inconsistencies || []).map(i => `<li>${escapeHtml(i)}</li>`).join('') || '<li class="muted">None.</li>';
                actionsEl.innerHTML = (data.actions || []).map(a => `<li>${escapeHtml(a)}</li>`).join('') || '<li class="muted">No further action recommended.</li>';
                approvalEl.textContent = data.approvalRequired || 'Yes — fraud-related decisions always require human approval.';

                renderDocCards(data.documents || [], !!data.contentUnderstandingConfigured);

                if (data.agentNotes) {
                    agentNotesEl.hidden = false;
                    agentNotesBody.classList.remove('agent-md-streaming');
                    window.zcRenderMarkdown(agentNotesBody, data.agentNotes);
                } else {
                    agentNotesEl.hidden = true;
                }

                outputStep.hidden = false;
                outputStep.scrollIntoView({ behavior: 'smooth', block: 'start' });

                // Surface input + raw output in the Engage Agent sub-tabs.
                if (window.engageTabsRender) {
                    const scope = document.querySelector('.fraud-panel .engage-tabs-scope');
                    window.engageTabsRender(scope, data);
                }
            } catch (err) {
                processStatus.className = 'fraud-status error';
                processStatus.textContent = 'Failed to process: ' + err.message;
            } finally {
                processBtn.disabled = false;
            }
        }

        selectEl.addEventListener('change', () => selectClaim(selectEl.value));
        refreshBtn.addEventListener('click', () => loadClaims(true));
        processBtn.addEventListener('click', processClaim);

        loadClaims(false);
        }

        init();

        if (!window.__fraudDemoEnhancedHook) {
            window.__fraudDemoEnhancedHook = true;
            const hook = () => init();
            if (typeof Blazor !== 'undefined' && typeof Blazor.addEventListener === 'function') {
                Blazor.addEventListener('enhancedload', hook);
            } else {
                document.addEventListener('enhancedload', hook);
            }
        }
    })();
</script>
