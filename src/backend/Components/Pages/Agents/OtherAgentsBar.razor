@*
    Tiny shared component: the "Other agents in the claims office" pill bar
    rendered at the bottom of every per-agent page. Takes the current agent's
    id so it can be excluded from the list. Catalog lookup here is just for
    navigation links — every agent's content itself is hand-written HTML.
*@
@using ZavaClaims.App.Models

<section class="panel">
    <h2>Other agents in the claims office</h2>
    <div class="other-agents">
        @foreach (var other in AgentCatalog.All.Where(a => a.Id != CurrentId))
        {
            <a class="other-agent" href="@($"/agents/{other.Id}")">
                <span class="other-agent-icon">@other.Icon</span>
                <span>@other.Name</span>
            </a>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired] public string CurrentId { get; set; } = string.Empty;
}
