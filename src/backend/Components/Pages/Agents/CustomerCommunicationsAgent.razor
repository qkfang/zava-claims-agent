@page "/agents/customer-communications"

<PageTitle>Customer Communications Agent — Claims Team in a Day</PageTitle>

<div class="agent-header" style="--accent: #ec4899">
    <a class="back-link" href="/"><span aria-hidden="true">←</span> Back to claims office</a>
    <div class="agent-header-row">
        <div class="agent-header-icon">✉️</div>
        <div>
            <div class="agent-header-dept">Customer Communications</div>
            <h1>Customer Communications Agent</h1>
            <div class="agent-header-persona">Cara — Customer Communications Specialist</div>
            <p class="tagline">Plain-English, empathetic updates at every step of the claim.</p>
        </div>
    </div>
</div>

<div class="agent-tab-scope" style="--accent: #ec4899">
    <nav class="agent-tabs" role="tablist" aria-label="Customer Communications agent details">
        <button type="button" class="agent-tab active" data-tab="overview" role="tab" aria-selected="true" tabindex="0">Overview</button>
        <button type="button" class="agent-tab" data-tab="try" role="tab" aria-selected="false" tabindex="-1">Try it out</button>
        <button type="button" class="agent-tab" data-tab="voice" role="tab" aria-selected="false" tabindex="-1">Voice chat</button>
    </nav>

    <div class="agent-tab-panel active" data-panel="overview" role="tabpanel">
    <section class="panel" style="--accent: #ec4899">
        <h2>What this agent does</h2>
        <p>
            Drafts customer-facing emails, SMS, and call scripts that explain claim status and
            decisions clearly and empathetically — never inventing facts or making promises.
        </p>
        <div class="two-col">
            <div>
                <h3>Responsibilities</h3>
                <ul>
                    <li>Generate status updates whenever the claim moves stage.</li>
                    <li>Translate technical assessment notes into plain English.</li>
                    <li>Match tone to customer sentiment and situation.</li>
                    <li>Run a compliance check on every outgoing message.</li>
                    <li>Provide a call script when a phone follow-up is recommended.</li>
                </ul>
            </div>
            <div>
                <h3>Tools available</h3>
                <ul>
                    <li>Email/SMS drafting</li>
                    <li>Tone adjustment</li>
                    <li>Plain-English rewriter</li>
                    <li>Template library</li>
                    <li>Compliance checker</li>
                </ul>
                <h3>Human approval</h3>
                <p class="approval">
                    Required for declines, complaint responses, sensitive claims, bereavement,
                    and any legal or regulatory wording.
                </p>
            </div>
        </div>
    </section>

    <section class="panel" style="--accent: #ec4899">
        <h2>How this agent helps with the claim</h2>
        <div class="demo">
            <p>
                Whenever a claim moves to a new stage, Cara's communications agent drafts the
                update for the customer in plain, empathetic English — matched to their preferred
                channel and tone. Acknowledgements, inspection bookings, decisions, and
                settlement letters are all turned around in seconds, drawing only on facts that
                are already in the claim file.
            </p>
            <p>
                Every draft is run through a compliance check before it goes anywhere near a
                customer, and sensitive messages — declines, complaints, bereavement — always
                go to a human reviewer first. The result is consistently clear, kind updates
                without anyone in the office spending their day rewriting templates.
            </p>
        </div>
    </section>

    </div>

    <div class="agent-tab-panel" data-panel="try" role="tabpanel">
    <section class="panel comms-panel" style="--accent: #ec4899">
        <h2>Try It Out — Customer Communications Demo</h2>
        <p class="muted comms-help">
            Pick a claim Iris has already lodged from the
            <a href="/agents/claims-intake">Claims Intake</a> demo, and watch
            Cara draft the customer-facing updates — clear, empathetic, and
            compliance-checked. All steps run live against the
            <code>/communications/*</code> endpoints in this app.
        </p>

        <!-- Step 1 — pick a claim -->
        <div class="comms-step" data-step="1">
            <div class="comms-step-head">
                <span class="comms-step-num">1</span>
                <h3>Select a claim</h3>
            </div>
            <p class="muted">
                The dropdown is populated from claims minted by the Claims Intake
                demo. If it's empty, run an intake sample first.
            </p>
            <div class="comms-pick-row">
                <select id="comms-claim-select" class="comms-select" disabled>
                    <option value="">Loading claims…</option>
                </select>
                <button type="button" id="comms-refresh-btn" class="comms-secondary" title="Refresh claim list">↻ Refresh</button>
            </div>
            <div class="comms-claim-summary" id="comms-claim-summary" hidden>
                <div class="comms-claim-summary-grid">
                    <div><span class="k">Customer</span><span id="comms-cust-name"></span></div>
                    <div><span class="k">Policy</span><span id="comms-cust-policy"></span></div>
                    <div><span class="k">Claim type</span><span id="comms-cust-type"></span></div>
                    <div><span class="k">Urgency</span><span id="comms-cust-urgency"></span></div>
                    <div class="span-2"><span class="k">Incident</span><span id="comms-cust-incident"></span></div>
                    <div class="span-2"><span class="k">Preferred contact</span><span id="comms-cust-pref"></span></div>
                </div>
            </div>
        </div>

        <!-- Step 2 — engage the agent -->
        <div class="comms-step" data-step="2" id="comms-step-2" hidden>
            <div class="comms-step-head">
                <span class="comms-step-num">2</span>
                <h3>Engage Customer Communications Agent</h3>
            </div>
            <p class="muted">
                Cara reads the claim, drafts customer-facing updates across the most
                appropriate channels, summarises what comes next, and flags anything
                that needs a human reviewer before it's sent.
            </p>
            <button id="comms-process-btn" type="button" disabled>Draft customer updates with Cara</button>
            <div id="comms-process-status" class="comms-status" hidden></div>

            <div class="engage-tabs-scope" data-engage-role="communications">
                <div class="engage-tabs" role="tablist">
                    <button type="button" class="engage-tab-btn active" data-engage-tab="narrative">Agent Narrative</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="reference">Reference</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="prompt">Agent Prompt &amp; Tools</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="input">Agent Input</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="output">Raw Output</button>
                </div>

                <div class="engage-tab-panel active" data-engage-tab="narrative">
                    <div class="engage-info-block">
                        <h4>Agent narrative (streamed)</h4>
                        <div class="agent-md engage-narrative-body"><div class="engage-empty">Engage the agent to see the streamed narrative.</div></div>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="reference">
                    <div class="engage-info-block">
                        <h4>Reference documents cited by the agent</h4>
                        <div class="engage-references-body"><div class="engage-empty">Engage the agent to see the reference documents cited in its response.</div></div>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="prompt">
                    <div class="engage-info-block">
                        <h4>Agent metadata</h4>
                        <div class="engage-info-meta engage-meta"></div>
                    </div>
                    <div class="engage-info-block">
                        <h4>System prompt</h4>
                        <pre class="engage-pre engage-prompt-body">Loading…</pre>
                    </div>
                    <div class="engage-info-block">
                        <h4>Tools available</h4>
                        <ul class="engage-tools-list"><li class="engage-empty">Loading…</li></ul>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="input">
                    <div class="engage-info-block">
                        <h4>Prompt sent to the agent</h4>
                        <pre class="engage-pre engage-input-body engage-empty">Engage the agent to capture the input that was sent.</pre>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="output">
                    <div class="engage-info-block">
                        <h4>Raw agent output (text, citations, every output item including tool / function calls)</h4>
                        <div class="json-viewer engage-output-body"><div class="engage-empty">Engage the agent to see the full raw response.</div></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 3 — claim summary & flags -->
        <div class="comms-step" data-step="3" id="comms-results" hidden>
            <div class="comms-step-head">
                <span class="comms-step-num">3</span>
                <h3>Cara's claim summary</h3>
            </div>

            <div class="comms-summary-card">
                <div class="comms-summary-head">
                    <span class="comms-summary-label">Status &amp; next steps</span>
                    <span class="comms-stage-pill" id="comms-stage-pill"></span>
                </div>
                <p id="comms-summary-text"></p>
                <ul id="comms-next-steps" class="comms-next-steps"></ul>
            </div>

            <div class="comms-flags" id="comms-flags" hidden>
                <div class="comms-flags-head">
                    <span class="comms-flags-icon" aria-hidden="true">⚠️</span>
                    <span class="comms-flags-title">Vulnerability flags — human review</span>
                    <span class="comms-approval-pill" id="comms-approval-pill"></span>
                </div>
                <ul id="comms-flags-list"></ul>
                <p class="muted" id="comms-approval-reason"></p>
            </div>
        </div>

        <!-- Step 4 — customer-facing drafts -->
        <div class="comms-step" data-step="4" id="comms-drafts" hidden>
            <div class="comms-step-head">
                <span class="comms-step-num">4</span>
                <h3>Customer-facing drafts</h3>
            </div>
            <p class="muted">
                Email, SMS, and portal updates drafted by Cara — ready for a
                human reviewer to approve before they're sent.
            </p>

            <div class="comms-channels">
                <div class="comms-channel">
                    <div class="comms-channel-head">
                        <span class="comms-channel-icon" aria-hidden="true">✉️</span>
                        <span class="comms-channel-title">Email draft</span>
                    </div>
                    <div class="comms-email-subject"><span class="k">Subject</span><span id="comms-email-subject"></span></div>
                    <div class="comms-channel-body agent-md" id="comms-email-body"></div>
                </div>

                <div class="comms-channel">
                    <div class="comms-channel-head">
                        <span class="comms-channel-icon" aria-hidden="true">📱</span>
                        <span class="comms-channel-title">SMS draft</span>
                    </div>
                    <div class="comms-channel-body comms-sms agent-md" id="comms-sms-body"></div>
                </div>

                <div class="comms-channel">
                    <div class="comms-channel-head">
                        <span class="comms-channel-icon" aria-hidden="true">🔔</span>
                        <span class="comms-channel-title">Portal status</span>
                    </div>
                    <div class="comms-portal-heading" id="comms-portal-heading"></div>
                    <div class="comms-channel-body agent-md" id="comms-portal-body"></div>
                </div>
            </div>
        </div>
    </section>
    </div>

    <div class="agent-tab-panel" data-panel="voice" role="tabpanel">
    <section class="panel voice-panel" style="--accent: #ec4899">
        <h2>Voice chat with Cara</h2>
        <p class="muted voice-help">
            Talk to Cara directly from your browser using the
            <strong>Azure AI Foundry Voice Live API</strong> — a real-time
            speech-to-speech connection to the Customer Communications
            Foundry agent. Press the mic, speak naturally, and Cara will
            reply out loud. You can interrupt her at any time. Optionally
            pick a claim first so Cara has the context. The mic streams
            24&nbsp;kHz PCM audio over a secure WebSocket proxy on this
            server; works best in Chrome / Edge / Safari on
            <code>localhost</code> or over <code>https</code>.
        </p>

        <div class="voice-context-row">
            <label class="voice-context-label" for="voice-claim-select">Claim context (optional)</label>
            <select id="voice-claim-select" class="comms-select voice-select" disabled>
                <option value="">Loading claims…</option>
            </select>
            <button type="button" id="voice-refresh-btn" class="comms-secondary" title="Refresh claim list">↻ Refresh</button>
        </div>

        <div class="voice-stage" aria-live="polite">
            <button type="button" id="voice-mic-btn" class="voice-mic" aria-pressed="false" aria-label="Start talking to Cara">
                <span class="voice-mic-icon" aria-hidden="true">
                    <i class="fa-solid fa-microphone"></i>
                </span>
                <span class="voice-mic-label">Press to talk</span>
            </button>

            <div class="voice-wave" id="voice-wave" aria-hidden="true">
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
            </div>

            <div class="voice-status" id="voice-status">Idle. Press the mic and start speaking — Cara is listening.</div>
        </div>

        <div class="voice-text-row">
            <input type="text" id="voice-text-input" class="voice-text-input" placeholder="…or type a message and press Enter" />
            <button type="button" id="voice-text-send" class="voice-text-send">Send</button>
            <label class="voice-toggle">
                <input type="checkbox" id="voice-tts-toggle" checked />
                <span>Speak replies</span>
            </label>
        </div>

        <div class="voice-transcript" id="voice-transcript" role="log" aria-live="polite">
            <div class="voice-empty">Your conversation with Cara will appear here.</div>
        </div>
    </section>
    </div>
</div>

<style>
    .comms-panel { --comms-accent: #ec4899; }
    .comms-help { margin-bottom: 0.9rem; }
    .comms-help code { background: rgba(236, 72, 153, 0.12); padding: 1px 6px; border-radius: 4px; font-size: 0.85rem; }
    .comms-help a { color: var(--comms-accent); }

    .comms-step {
        border: 1px solid rgba(120, 150, 200, 0.18);
        background: rgba(15, 22, 38, 0.4);
        border-radius: 12px;
        padding: 0.95rem 1.1rem 1rem 1.1rem;
        margin-top: 0.9rem;
    }
    .comms-step-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.3rem; }
    .comms-step-head h3 { margin: 0; color: #fff; font-size: 1rem; }
    .comms-step-num {
        display: inline-grid; place-items: center;
        width: 1.55rem; height: 1.55rem;
        border-radius: 50%;
        background: color-mix(in srgb, var(--comms-accent) 22%, rgba(20, 28, 46, 0.7));
        border: 1px solid color-mix(in srgb, var(--comms-accent) 55%, transparent);
        color: var(--comms-accent);
        font-size: 0.78rem; font-weight: 700;
    }
    .comms-step .muted { color: var(--zava-muted, #97a3b6); font-size: 0.9rem; margin: 0.35rem 0 0.7rem 0; }

    .comms-pick-row { display: flex; flex-wrap: wrap; gap: 0.55rem; align-items: center; }
    .comms-select {
        flex: 1 1 320px;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.28);
        color: #fff;
        font-size: 0.9rem;
        padding: 0.5rem 0.7rem;
        border-radius: 6px;
        font-family: inherit;
    }
    .comms-select:focus { outline: none; border-color: var(--comms-accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--comms-accent) 25%, transparent); }
    .comms-select:disabled { opacity: 0.6; cursor: not-allowed; }
    .comms-secondary {
        background: transparent;
        color: rgba(238, 242, 247, 0.86);
        border: 1px solid rgba(120, 150, 200, 0.32);
        border-radius: 6px;
        padding: 0.45rem 0.85rem;
        font-size: 0.85rem;
        cursor: pointer;
    }
    .comms-secondary:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }

    .comms-claim-summary {
        margin-top: 0.7rem;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 8px;
        padding: 0.7rem 0.85rem;
    }
    .comms-claim-summary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.4rem 0.85rem;
        font-size: 0.85rem;
        color: rgba(238, 242, 247, 0.88);
    }
    .comms-claim-summary-grid .span-2 { grid-column: span 2; }
    @@media (max-width: 720px) {
        .comms-claim-summary-grid { grid-template-columns: 1fr; }
        .comms-claim-summary-grid .span-2 { grid-column: span 1; }
    }
    .comms-claim-summary-grid .k {
        display: inline-block; min-width: 110px;
        color: var(--zava-muted, #97a3b6); font-weight: 600;
        text-transform: uppercase; font-size: 0.66rem; letter-spacing: 0.08em;
        margin-right: 0.5rem;
    }

    #comms-process-btn {
        background: var(--comms-accent);
        color: #2a0418;
        border: none;
        border-radius: 8px;
        padding: 0.55rem 1.1rem;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 0.35rem;
    }
    #comms-process-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .comms-status { margin-top: 0.6rem; font-size: 0.88rem; color: rgba(238, 242, 247, 0.88); }
    .comms-status.error { color: #fca5a5; }
    .comms-status .spinner {
        display: inline-block; width: 12px; height: 12px;
        border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
        border-radius: 50%; margin-right: 6px; vertical-align: middle;
        animation: comms-spin 0.7s linear infinite;
    }
    @@keyframes comms-spin { to { transform: rotate(360deg); } }

    .comms-summary-card {
        margin-top: 0.6rem;
        background: color-mix(in srgb, var(--comms-accent) 8%, rgba(15, 22, 38, 0.7));
        border: 1px solid color-mix(in srgb, var(--comms-accent) 30%, transparent);
        border-radius: 10px;
        padding: 0.75rem 0.95rem;
    }
    .comms-summary-head { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0.3rem; }
    .comms-summary-label {
        color: #fff; font-weight: 700; font-size: 0.92rem;
    }
    .comms-stage-pill {
        margin-left: auto;
        padding: 0.15rem 0.7rem;
        border-radius: 999px;
        font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
        background: color-mix(in srgb, var(--comms-accent) 18%, transparent);
        color: #ffd6e9;
        border: 1px solid color-mix(in srgb, var(--comms-accent) 45%, transparent);
    }
    .comms-summary-card p { margin: 0; color: rgba(238, 242, 247, 0.9); font-size: 0.9rem; line-height: 1.5; }
    .comms-next-steps {
        margin: 0.55rem 0 0 1.1rem;
        padding: 0;
        color: rgba(238, 242, 247, 0.85);
        font-size: 0.85rem;
        line-height: 1.5;
    }
    .comms-next-steps li { margin-bottom: 0.2rem; }

    .comms-flags {
        margin-top: 0.8rem;
        background: rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.4);
        border-radius: 10px;
        padding: 0.7rem 0.9rem;
    }
    .comms-flags-head { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0.35rem; }
    .comms-flags-title { color: #fde68a; font-weight: 700; font-size: 0.9rem; }
    .comms-flags-icon { font-size: 1rem; }
    .comms-approval-pill {
        margin-left: auto;
        padding: 0.15rem 0.7rem;
        border-radius: 999px;
        font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
    }
    .comms-approval-pill.required { background: rgba(239, 68, 68, 0.18); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.4); }
    .comms-approval-pill.optional { background: rgba(34, 197, 94, 0.16); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.4); }
    .comms-flags ul { margin: 0.25rem 0 0.4rem 1.1rem; padding: 0; color: rgba(238, 242, 247, 0.9); font-size: 0.86rem; line-height: 1.5; }
    .comms-flags ul li { margin-bottom: 0.2rem; }

    .comms-channels {
        margin-top: 0.85rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.7rem;
    }
    @@media (max-width: 820px) { .comms-channels { grid-template-columns: 1fr; } }
    .comms-channel {
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 10px;
        padding: 0.7rem 0.85rem;
    }
    .comms-channel:first-child { grid-column: span 2; }
    @@media (max-width: 820px) { .comms-channel:first-child { grid-column: span 1; } }
    .comms-channel-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
    .comms-channel-title { color: #fff; font-weight: 700; font-size: 0.88rem; }
    .comms-channel-icon { font-size: 1rem; }
    .comms-email-subject {
        font-size: 0.82rem;
        color: rgba(238, 242, 247, 0.86);
        margin-bottom: 0.4rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px dashed rgba(120, 150, 200, 0.2);
    }
    .comms-email-subject .k {
        display: inline-block; min-width: 60px;
        color: var(--zava-muted, #97a3b6); font-weight: 600;
        text-transform: uppercase; font-size: 0.66rem; letter-spacing: 0.08em;
        margin-right: 0.5rem;
    }
    .comms-portal-heading {
        font-size: 0.85rem; font-weight: 700; color: #ffd6e9;
        margin-bottom: 0.35rem;
    }
    .comms-channel-body {
        background: rgba(8, 12, 22, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.16);
        border-radius: 6px;
        padding: 0.65rem 0.8rem;
        color: rgba(238, 242, 247, 0.88);
        font-size: 0.84rem;
        line-height: 1.5;
        margin: 0;
    }
    .comms-channel-body.comms-sms { font-size: 0.85rem; }

    /* Voice chat tab */
    .voice-panel { --voice-accent: #ec4899; }
    .voice-help { margin-bottom: 0.9rem; }
    .voice-help code {
        background: rgba(236, 72, 153, 0.12);
        padding: 1px 6px; border-radius: 4px; font-size: 0.85rem;
    }

    .voice-context-row {
        display: flex; flex-wrap: wrap; gap: 0.55rem; align-items: center;
        margin-bottom: 0.85rem;
    }
    .voice-context-label {
        color: var(--zava-muted, #97a3b6);
        font-size: 0.72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
    }
    .voice-select { flex: 1 1 320px; }

    .voice-stage {
        display: flex; flex-direction: column; align-items: center;
        gap: 0.85rem;
        padding: 1.4rem 1rem 1.2rem 1rem;
        border: 1px solid color-mix(in srgb, var(--voice-accent) 28%, transparent);
        background:
            radial-gradient(circle at 50% 30%, color-mix(in srgb, var(--voice-accent) 14%, transparent) 0%, transparent 65%),
