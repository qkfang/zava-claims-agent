@page "/agents/claims-assessment"

<PageTitle>Claims Assessment Agent — Claims Team in a Day</PageTitle>

<div class="agent-header" style="--accent: #6366f1">
    <a class="back-link" href="/"><span aria-hidden="true">←</span> Back to claims office</a>
    <div class="agent-header-row">
        <div class="agent-header-icon">📋</div>
        <div>
            <div class="agent-header-dept">Claims Assessment</div>
            <h1>Claims Assessment Agent</h1>
            <div class="agent-header-persona">Adam — Claims Assessor</div>
            <p class="tagline">Reads the policy, checks the evidence, recommends the call.</p>
        </div>
    </div>
</div>

<div class="agent-tab-scope" style="--accent: #6366f1">
    <nav class="agent-tabs" role="tablist" aria-label="Claims Assessment agent details">
        <button type="button" class="agent-tab active" data-tab="overview" role="tab" aria-selected="true" tabindex="0">Overview</button>
        <button type="button" class="agent-tab" data-tab="try" role="tab" aria-selected="false" tabindex="-1">Try it out</button>
    </nav>

    <div class="agent-tab-panel active" data-panel="overview" role="tabpanel">
    <section class="panel" style="--accent: #6366f1">
        <h2>What this agent does</h2>
        <p>
            Reviews the open Claim Case against the policy wording and submitted evidence,
            identifies coverage and exclusions, and recommends approve / partial / decline
            for a human to confirm.
        </p>
        <div class="two-col">
            <div>
                <h3>Responsibilities</h3>
                <ul>
                    <li>Pull the policy wording, limits, and exclusions for the customer.</li>
                    <li>Compare the incident description and evidence against coverage.</li>
                    <li>List missing information needed to make a decision.</li>
                    <li>Draft a plain-English assessment summary citing policy clauses.</li>
                    <li>Recommend approve, partial approve, or decline.</li>
                </ul>
            </div>
            <div>
                <h3>Tools available</h3>
                <ul>
                    <li>Policy search</li>
                    <li>Coverage rules engine</li>
                    <li>Document summariser</li>
                    <li>Evidence checklist</li>
                    <li>Decision-letter draft</li>
                </ul>
                <h3>Human approval</h3>
                <p class="approval">
                    Required for declines, partial settlements, ambiguous policy wording,
                    high-value claims, or escalations.
                </p>
            </div>
        </div>
    </section>

    <section class="panel" style="--accent: #6366f1">
        <h2>How this agent helps with the claim</h2>
        <div class="demo">
            <p>
                Once Intake has opened a Claim Case, Adam's assessment agent loads the customer's
                policy wording and lines up the incident, the photos, and any supporting reports.
                It works through the relevant clauses, applies excess and limit rules, and produces
                a clear coverage view in plain English — citing the exact clause that supports each
                decision.
            </p>
            <p>
                The agent then drafts a recommendation — approve, partial, or decline — together
                with the calculation and a list of any remaining gaps. A human assessor or team
                leader reviews and signs off, so every customer-facing decision is owned by a person
                while the agent does the careful policy reading.
            </p>
        </div>
    </section>

    </div>

    <div class="agent-tab-panel" data-panel="try" role="tabpanel">
    <section class="panel assessment-panel" style="--accent: #6366f1">
        <h2>Try It Out — Claims Assessment Demo</h2>
        <p class="muted assessment-help">
            Pick a Claim Case opened by the
            <a href="/agents/claims-intake">Claims Intake demo</a>, review the
            captured fields, then engage Adam's assessment agent. The agent loads
            the policy wording, lines it up with the incident, and returns a
            coverage recommendation citing the relevant clauses.
        </p>

        <!-- Step 1 — pick a claim -->
        <div class="assessment-step" data-step="1">
            <div class="assessment-step-head">
                <span class="assessment-step-num">1</span>
                <h3>Pick a claim</h3>
            </div>
            <p class="muted">
                Claim cases minted by the Claims Intake "Try It Out" demo are kept
                in memory and surface here.
            </p>
            <div class="assessment-picker">
                <label for="assessment-claim-select" class="assessment-picker-label">Claim number</label>
                <select id="assessment-claim-select" class="assessment-claim-select">
                    <option value="">— Loading claims —</option>
                </select>
                <button type="button" id="assessment-refresh-btn" class="assessment-refresh" title="Refresh claim list">↻</button>
            </div>
            <div id="assessment-empty" class="assessment-empty" hidden>
                No claims are in memory yet. Lodge one from the
                <a href="/agents/claims-intake">Claims Intake</a> Try It Out tab,
                then come back.
            </div>
        </div>

        <!-- Step 2 — review the claim case -->
        <div class="assessment-step" data-step="2" id="assessment-claim-card-step" hidden>
            <div class="assessment-step-head">
                <span class="assessment-step-num">2</span>
                <h3>Review the claim case</h3>
            </div>
            <p class="muted">Captured by Iris on intake. Adam's agent will assess this against the policy.</p>
            <div class="assessment-claim-card" id="assessment-claim-card"></div>
        </div>

        <!-- Step 3 — engage the agent -->
        <div class="assessment-step" data-step="3" id="assessment-process-step" hidden>
            <div class="assessment-step-head">
                <span class="assessment-step-num">3</span>
                <h3>Engage Claims Assessment Agent</h3>
            </div>
            <p class="muted">
                The agent pulls the relevant policy wording, compares it against the
                incident and evidence, lists any missing information, and recommends
                approve, partial, or decline.
            </p>
            <button id="assessment-process-btn" type="button">Process with Claims Assessment Agent</button>
            <div id="assessment-process-status" class="assessment-status" hidden></div>

            <div id="assessment-result" class="assessment-result" hidden>
                <div class="assessment-result-head">
                    <span class="assessment-result-pill" id="assessment-result-pill"></span>
                    <span class="assessment-result-title">Assessment recommendation</span>
                </div>
                <div id="assessment-result-body" class="agent-md"></div>
            </div>

            <!-- Step 3a — visual policy + checklist (decided by the agent's output) -->
            <div id="assessment-validation" class="assessment-validation" hidden>
                <div class="assessment-validation-grid">
                    <div class="assessment-policy-card" id="assessment-policy-card"></div>
                    <div class="assessment-checklist-card">
                        <div class="assessment-checklist-head">
                            <span class="assessment-result-pill" id="assessment-checklist-pill"></span>
                            <span class="assessment-result-title">Policy validation checklist</span>
                        </div>
                        <ul class="assessment-checklist" id="assessment-checklist"></ul>
                        <div class="assessment-decision">
                            <h4>Reason for decision</h4>
                            <p id="assessment-decision-reason"></p>
                            <h4>Settlement position</h4>
                            <p id="assessment-decision-settlement"></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="engage-tabs-scope" data-engage-role="claims-assessment">
                <div class="engage-tabs" role="tablist">
                    <button type="button" class="engage-tab-btn active" data-engage-tab="narrative">Agent Narrative</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="prompt">Agent Prompt &amp; Tools</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="input">Agent Input</button>
                    <button type="button" class="engage-tab-btn" data-engage-tab="output">Raw Output</button>
                </div>

                <div class="engage-tab-panel active" data-engage-tab="narrative">
                    <div class="engage-info-block">
                        <h4>Agent narrative (streamed)</h4>
                        <div class="agent-md engage-narrative-body"><div class="engage-empty">Engage the agent to see the streamed narrative.</div></div>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="prompt">
                    <div class="engage-info-block">
                        <h4>Agent metadata</h4>
                        <div class="engage-info-meta engage-meta"></div>
                    </div>
                    <div class="engage-info-block">
                        <h4>System prompt</h4>
                        <pre class="engage-pre engage-prompt-body">Loading…</pre>
                    </div>
                    <div class="engage-info-block">
                        <h4>Tools available</h4>
                        <ul class="engage-tools-list"><li class="engage-empty">Loading…</li></ul>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="input">
                    <div class="engage-info-block">
                        <h4>Prompt sent to the agent</h4>
                        <pre class="engage-pre engage-input-body engage-empty">Engage the agent to capture the input that was sent.</pre>
                    </div>
                </div>

                <div class="engage-tab-panel" data-engage-tab="output">
                    <div class="engage-info-block">
                        <h4>Raw agent output (text, citations, every output item including tool / function calls)</h4>
                        <div class="json-viewer engage-output-body"><div class="engage-empty">Engage the agent to see the full raw response.</div></div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    </div>
</div>

<style>
    .assessment-panel { --assessment-accent: #6366f1; }
    .assessment-help { margin-bottom: 0.9rem; }
    .assessment-help code { background: rgba(165, 180, 252, 0.14); padding: 1px 6px; border-radius: 4px; font-size: 0.85rem; }

    .assessment-step {
        border: 1px solid rgba(120, 150, 200, 0.18);
        background: rgba(15, 22, 38, 0.4);
        border-radius: 12px;
        padding: 0.95rem 1.1rem 1rem 1.1rem;
        margin-top: 0.9rem;
    }
    .assessment-step-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.3rem; }
    .assessment-step-head h3 { margin: 0; color: #fff; font-size: 1rem; }
    .assessment-step-num {
        display: inline-grid; place-items: center;
        width: 1.55rem; height: 1.55rem;
        border-radius: 50%;
        background: color-mix(in srgb, var(--assessment-accent) 22%, rgba(20, 28, 46, 0.7));
        border: 1px solid color-mix(in srgb, var(--assessment-accent) 55%, transparent);
        color: var(--assessment-accent);
        font-size: 0.78rem; font-weight: 700;
    }
    .assessment-step .muted { color: var(--zava-muted, #97a3b6); font-size: 0.9rem; margin: 0.35rem 0 0.7rem 0; }

    .assessment-picker { display: flex; align-items: center; gap: 0.55rem; flex-wrap: wrap; }
    .assessment-picker-label {
        font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--zava-muted, #97a3b6); font-weight: 700;
    }
    .assessment-claim-select {
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.25);
        color: #fff;
        padding: 0.5rem 0.7rem;
        border-radius: 6px;
        font-size: 0.9rem;
        min-width: 320px;
        font-family: inherit;
    }
    .assessment-claim-select:focus {
        outline: none;
        border-color: var(--assessment-accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--assessment-accent) 25%, transparent);
    }
    .assessment-refresh {
        background: transparent;
        color: rgba(238, 242, 247, 0.86);
        border: 1px solid rgba(120, 150, 200, 0.32);
        border-radius: 6px;
        padding: 0.35rem 0.6rem;
        font-size: 0.95rem;
        cursor: pointer;
    }
    .assessment-refresh:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }

    .assessment-empty {
        margin-top: 0.7rem;
        padding: 0.7rem 0.9rem;
        background: rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.3);
        border-radius: 8px;
        color: #fcd34d;
        font-size: 0.88rem;
    }
    .assessment-empty a { color: #fde68a; }

    .assessment-claim-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.45rem 1.2rem;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 8px;
        padding: 0.85rem 1rem;
        font-size: 0.88rem;
        color: rgba(238, 242, 247, 0.88);
    }
    @@media (max-width: 820px) { .assessment-claim-card { grid-template-columns: 1fr; } }
    .assessment-claim-card .row { display: flex; gap: 0.5rem; }
    .assessment-claim-card .row.span-2 { grid-column: span 2; }
    @@media (max-width: 820px) { .assessment-claim-card .row.span-2 { grid-column: span 1; } }
    .assessment-claim-card .k {
        min-width: 110px;
        color: var(--zava-muted, #97a3b6);
        text-transform: uppercase; font-size: 0.66rem; letter-spacing: 0.08em;
        font-weight: 700;
        padding-top: 0.15rem;
    }
    .assessment-claim-card .v { color: rgba(238, 242, 247, 0.92); }
    .assessment-claim-card .v.mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }
    .assessment-claim-card .urg-pill {
        display: inline-block;
        padding: 0.05rem 0.55rem;
        border-radius: 999px;
        font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
    }
    .assessment-claim-card .urg-pill.high   { background: rgba(239, 68, 68, 0.18); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.4); }
    .assessment-claim-card .urg-pill.medium { background: rgba(245, 158, 11, 0.18); color: #fcd34d; border: 1px solid rgba(245, 158, 11, 0.4); }
    .assessment-claim-card .urg-pill.low    { background: rgba(34, 197, 94, 0.16); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.4); }

    #assessment-process-btn {
        background: var(--assessment-accent);
        color: #0b0f24;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.88rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 0.35rem;
    }
    #assessment-process-btn:disabled { opacity: 0.55; cursor: not-allowed; }

    .assessment-status {
        margin-top: 0.6rem; font-size: 0.88rem;
        color: rgba(238, 242, 247, 0.88);
    }
    .assessment-status.error { color: #fca5a5; }
    .assessment-status .spinner {
        display: inline-block; width: 12px; height: 12px;
        border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
        border-radius: 50%; margin-right: 6px; vertical-align: middle;
        animation: assessment-spin 0.7s linear infinite;
    }
    @@keyframes assessment-spin { to { transform: rotate(360deg); } }

    .assessment-result {
        margin-top: 0.8rem;
        background: color-mix(in srgb, var(--assessment-accent) 8%, rgba(10, 16, 28, 0.7));
        border: 1px solid color-mix(in srgb, var(--assessment-accent) 35%, transparent);
        border-radius: 10px;
        padding: 0.85rem 1rem;
    }
    .assessment-result-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem; }
    .assessment-result-title { color: #fff; font-weight: 700; font-size: 0.92rem; }
    .assessment-result-pill {
        padding: 0.18rem 0.7rem;
        border-radius: 999px;
        font-size: 0.72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.08em;
        background: rgba(165, 180, 252, 0.18);
        color: #c7d2fe;
        border: 1px solid rgba(165, 180, 252, 0.4);
    }
    .assessment-result-pill.approve { background: rgba(34, 197, 94, 0.16); color: #86efac; border-color: rgba(34, 197, 94, 0.4); }
    .assessment-result-pill.partial { background: rgba(245, 158, 11, 0.18); color: #fcd34d; border-color: rgba(245, 158, 11, 0.4); }
    .assessment-result-pill.decline { background: rgba(239, 68, 68, 0.18); color: #fca5a5; border-color: rgba(239, 68, 68, 0.4); }
    .assessment-result-pill.info    { background: rgba(110, 193, 255, 0.14); color: #d6ecff; border-color: rgba(110, 193, 255, 0.35); }
    .assessment-result pre {
        color: rgba(238, 242, 247, 0.9);
        font-size: 0.85rem;
        line-height: 1.55;
        white-space: pre-wrap;
        margin: 0;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    /* ── Policy + checklist (visual validation) ─────────────────────────── */
    .assessment-validation { margin-top: 0.9rem; }
    .assessment-validation-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
        gap: 1rem;
    }
    @@media (max-width: 980px) { .assessment-validation-grid { grid-template-columns: 1fr; } }

    .assessment-policy-card,
    .assessment-checklist-card {
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.22);
        border-radius: 10px;
        padding: 0.95rem 1rem 1rem 1rem;
        font-size: 0.88rem;
        color: rgba(238, 242, 247, 0.9);
    }

    .assessment-policy-card h4 {
        margin: 0 0 0.25rem 0;
        color: #fff;
        font-size: 0.95rem;
        display: flex; align-items: center; gap: 0.45rem;
    }
    .assessment-policy-card .doc-emoji { font-size: 1.05rem; }
    .assessment-policy-card .policy-meta {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.25rem 0.7rem;
        margin: 0.5rem 0 0.7rem 0;
    }
    .assessment-policy-card .policy-meta .k {
        color: var(--zava-muted, #97a3b6);
        text-transform: uppercase; font-size: 0.66rem; letter-spacing: 0.08em;
        font-weight: 700; padding-top: 0.15rem;
    }
    .assessment-policy-card .policy-meta .v.mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.85rem;
    }
    .assessment-policy-card .policy-preamble {
        font-size: 0.84rem;
        color: rgba(238, 242, 247, 0.78);
        margin: 0 0 0.7rem 0;
        font-style: italic;
        border-left: 2px solid rgba(165, 180, 252, 0.45);
        padding: 0.05rem 0 0.05rem 0.6rem;
    }
    .assessment-policy-card h5 {
        margin: 0.7rem 0 0.3rem 0;
        font-size: 0.78rem;
        color: var(--zava-muted, #97a3b6);
        text-transform: uppercase; letter-spacing: 0.09em;
        font-weight: 700;
    }
    .assessment-policy-card .policy-list { list-style: none; margin: 0; padding: 0; }
    .assessment-policy-card .policy-list li {
        padding: 0.45rem 0.55rem;
        border-radius: 7px;
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(120, 150, 200, 0.14);
        margin-bottom: 0.35rem;
    }
    .assessment-policy-card .policy-list li.entitlement { border-left: 3px solid #34d399; }
    .assessment-policy-card .policy-list li.exclusion   { border-left: 3px solid #fca5a5; }
    .assessment-policy-card .policy-list li.condition   { border-left: 3px solid #fcd34d; }
    .assessment-policy-card .policy-list .clause {
        display: inline-block;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.72rem;
        color: #c7d2fe;
        background: rgba(99, 102, 241, 0.16);
        padding: 0.05rem 0.45rem;
        border-radius: 4px;
        margin-right: 0.4rem;
    }
    .assessment-policy-card .policy-list .title {
        color: #fff; font-weight: 600;
    }
    .assessment-policy-card .policy-list .limit {
        margin-left: 0.4rem;
        color: #86efac; font-size: 0.78rem; font-weight: 600;
    }
    .assessment-policy-card .policy-list .desc {
        display: block;
        color: rgba(238, 242, 247, 0.82);
        font-size: 0.83rem;
        margin-top: 0.2rem;
        line-height: 1.45;
    }

    .assessment-checklist-head {
        display: flex; align-items: center; gap: 0.55rem;
        margin-bottom: 0.6rem;
    }
    .assessment-checklist {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    .assessment-checklist li {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.6rem;
        padding: 0.55rem 0.6rem;
        margin-bottom: 0.4rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(120, 150, 200, 0.14);
    }
    .assessment-checklist li.pass { border-left: 3px solid #34d399; }
    .assessment-checklist li.fail { border-left: 3px solid #f87171; background: rgba(239, 68, 68, 0.05); }
    .assessment-checklist li.info { border-left: 3px solid #fcd34d; }

    .assessment-checklist .icon {
        display: inline-grid; place-items: center;
        width: 22px; height: 22px;
        border-radius: 50%;
        font-size: 0.75rem; font-weight: 700;
        margin-top: 0.1rem;
    }
    .assessment-checklist .icon.pass { background: rgba(34, 197, 94, 0.2); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.5); }
    .assessment-checklist .icon.fail { background: rgba(239, 68, 68, 0.2); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.5); }
    .assessment-checklist .icon.info { background: rgba(245, 158, 11, 0.2); color: #fcd34d; border: 1px solid rgba(245, 158, 11, 0.5); }

    .assessment-checklist .label {
        color: #fff; font-weight: 600; font-size: 0.9rem;
        display: flex; align-items: center; gap: 0.45rem;
        flex-wrap: wrap;
    }
    .assessment-checklist .clause-ref {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.7rem;
        color: #c7d2fe;
        background: rgba(99, 102, 241, 0.16);
        padding: 0.05rem 0.4rem;
        border-radius: 4px;
        font-weight: 500;
    }
    .assessment-checklist .finding {
        color: rgba(238, 242, 247, 0.82);
        font-size: 0.83rem;
        line-height: 1.5;
        margin-top: 0.2rem;
    }

    .assessment-decision {
        margin-top: 0.8rem;
        padding-top: 0.6rem;
        border-top: 1px dashed rgba(120, 150, 200, 0.25);
    }
    .assessment-decision h4 {
        margin: 0.4rem 0 0.2rem 0;
        font-size: 0.78rem;
        color: var(--zava-muted, #97a3b6);
        text-transform: uppercase; letter-spacing: 0.09em;
        font-weight: 700;
    }
    .assessment-decision p {
        margin: 0;
        font-size: 0.86rem;
        line-height: 1.55;
        color: rgba(238, 242, 247, 0.9);
    }
</style>

