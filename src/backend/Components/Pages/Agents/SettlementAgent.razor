@page "/agents/settlement"

<PageTitle>Settlement Agent — Claims Team in a Day</PageTitle>

<div class="agent-header" style="--accent: #a855f7">
    <a class="back-link" href="/"><span aria-hidden="true">←</span> Back to claims office</a>
    <div class="agent-header-row">
        <div class="agent-header-icon">💳</div>
        <div>
            <div class="agent-header-dept">Settlement</div>
            <h1>Settlement Agent</h1>
            <div class="agent-header-persona">Seth — Settlement Officer</div>
            <p class="tagline">Does the maths transparently and prepares the payment.</p>
        </div>
    </div>
</div>

<div class="agent-tabs" role="tablist" aria-label="Settlement views">
    <button type="button" class="agent-tab active" role="tab"
            aria-selected="true" data-tab="overview">Overview</button>
    <button type="button" class="agent-tab" role="tab"
            aria-selected="false" data-tab="tryit">Try It Out</button>
</div>

<div class="agent-tab-panel tab-panel-overview active" data-panel="overview">
    <section class="panel" style="--accent: #a855f7">
        <h2>What this agent does</h2>
        <p>
            Calculates the payable amount using approved scope, policy limits, excess,
            depreciation, and prior payments, then prepares the payment and settlement letter
            for human approval.
        </p>
        <div class="two-col">
            <div>
                <h3>Responsibilities</h3>
                <ul>
                    <li>Pull approved scope, supplier invoice, and policy limits.</li>
                    <li>Apply excess, depreciation, sub-limits, and prior payments.</li>
                    <li>Show the calculation step by step.</li>
                    <li>Validate payee details and authority limits.</li>
                    <li>Draft the settlement letter and payment instruction.</li>
                </ul>
            </div>
            <div>
                <h3>Tools available</h3>
                <ul>
                    <li>Settlement calculator</li>
                    <li>Authority limit checker</li>
                    <li>Invoice matcher</li>
                    <li>Settlement letter generator</li>
                    <li>Payment API</li>
                </ul>
                <h3>Human approval</h3>
                <p class="approval">
                    Required for payment release, payee mismatch, high-value settlement, ex-gratia,
                    manual override, or customer dispute.
                </p>
            </div>
        </div>
    </section>

    <section class="panel" style="--accent: #a855f7">
        <h2>Demo: how this agent helps with the claim</h2>
        <div class="demo">
            <p>
                When the supplier invoice arrives, Seth's settlement agent matches it line-for-line
                against the approved scope, then applies the policy terms — excess, depreciation,
                sub-limits, and any prior payments. Every step of the calculation is shown
                transparently so the customer (and any auditor) can see exactly how the figure
                was reached.
            </p>
            <p>
                The agent validates the payee, checks the amount against authority limits, and
                drafts both the payment instruction and the settlement letter. Nothing is paid
                automatically: a human reviewer releases the payment, with the agent's working
                attached for the audit trail.
            </p>
        </div>
    </section>

    <OtherAgentsBar CurrentId="settlement" />
</div>

<div class="agent-tab-panel tab-panel-tryit" data-panel="tryit">
    <SettlementDemo />
</div>

<script>
    (function () {
        const tabs = document.querySelectorAll('.agent-tabs .agent-tab');
        if (!tabs.length) return;
        const panels = document.querySelectorAll('.agent-tab-panel');
        tabs.forEach(t => t.addEventListener('click', () => {
            const target = t.dataset.tab;
            tabs.forEach(x => {
                const on = x === t;
                x.classList.toggle('active', on);
                x.setAttribute('aria-selected', on ? 'true' : 'false');
            });
            panels.forEach(p => p.classList.toggle('active', p.dataset.panel === target));
        }));
    })();
</script>
