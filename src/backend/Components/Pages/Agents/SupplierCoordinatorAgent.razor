@page "/agents/supplier-coordinator"

<PageTitle>Supplier Coordinator Agent — Claims Team in a Day</PageTitle>

<div class="agent-header" style="--accent: #10b981">
    <a class="back-link" href="/"><span aria-hidden="true">←</span> Back to claims office</a>
    <div class="agent-header-row">
        <div class="agent-header-icon">🛠️</div>
        <div>
            <div class="agent-header-dept">Supplier Coordination</div>
            <h1>Supplier Coordinator Agent</h1>
            <div class="agent-header-persona">Sam — Supplier Coordinator</div>
            <p class="tagline">Books the right repairer at the right time and chases overdue jobs.</p>
        </div>
    </div>
</div>

<div class="agent-tabs" role="tablist" aria-label="Supplier Coordination views">
    <span class="agent-tab active" role="tab" aria-selected="true">Overview</span>
    <a class="agent-tab" role="tab" aria-selected="false"
       href="/agents/supplier-coordinator/demo">Try It Out →</a>
</div>

<div class="agent-tab-panel standalone" data-panel="overview">
    <section class="panel" style="--accent: #10b981">
        <h2>What this agent does</h2>
        <p>
            Recommends approved suppliers, schedules inspections and repairs, tracks SLAs,
            and keeps the claim file updated with supplier status.
        </p>
        <div class="two-col">
            <div>
                <h3>Responsibilities</h3>
                <ul>
                    <li>Match the loss to a suitable supplier in the customer's area.</li>
                    <li>Request quotes and book inspection or repair appointments.</li>
                    <li>Track SLA breaches and chase overdue suppliers.</li>
                    <li>Compare quotes against the approved scope of loss.</li>
                    <li>Draft customer-facing booking confirmations.</li>
                </ul>
            </div>
            <div>
                <h3>Tools available</h3>
                <ul>
                    <li>Supplier directory</li>
                    <li>Appointment scheduler</li>
                    <li>Quote request</li>
                    <li>SLA tracker</li>
                    <li>Invoice matcher</li>
                </ul>
                <h3>Human approval</h3>
                <p class="approval">
                    Required for non-preferred supplier, high-cost quotes, supplier disputes,
                    scope variations, or customer complaints about a supplier.
                </p>
            </div>
        </div>
    </section>

    <section class="panel" style="--accent: #10b981">
        <h2>Demo: how this agent helps with the claim</h2>
        <div class="demo">
            <p>
                Once a claim is approved, Sam's supplier coordinator agent matches the loss to
                the right supplier on Zava's approved network — by location, capacity, and SLA
                track record. It requests quotes, books appointments, and arranges any rental
                or temporary accommodation the policy supports.
            </p>
            <p>
                From there the agent quietly tracks every job: chasing overdue quotes, comparing
                invoices against the agreed scope, and drafting clear booking confirmations for
                the customer. Anything outside policy — a non-preferred supplier, an over-budget
                quote, a scope variation — is held for a human to approve before it goes ahead.
            </p>
        </div>
    </section>

    <OtherAgentsBar CurrentId="supplier-coordinator" />
</div>
