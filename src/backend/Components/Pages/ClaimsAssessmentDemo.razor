@page "/agents/claims-assessment/demo"

@*
    Interactive "Try It Out" demo for the Claims Assessment Agent.

    Step 1 — pick a claim from the dropdown (sourced from claims minted by
             the Claims Intake demo and held in the in-memory IntakeClaimStore).
    Step 2 — review the claim case the dropdown selection loaded.
    Step 3 — engage the Claims Assessment Agent (Foundry) on that claim and
             render its coverage recommendation + plain-English explanation.

    Endpoints:
      GET  /assessment/claims                — dropdown list
      GET  /assessment/claims/{claimNumber}  — claim details
      POST /assessment/process               — engage the Foundry agent
*@

<PageTitle>Try It Out — Claims Assessment Agent — Claims Team in a Day</PageTitle>

<div class="agent-header" style="--accent: #6366f1">
    <a class="back-link" href="/agents/claims-assessment"><span aria-hidden="true">←</span> Back to Claims Assessment Agent</a>
    <div class="agent-header-row">
        <div class="agent-header-icon">📋</div>
        <div>
            <div class="agent-header-dept">Claims Assessment</div>
            <h1>Try It Out — Claims Assessment</h1>
            <div class="agent-header-persona">Adam — Claims Assessor</div>
            <p class="tagline">Pick a claim, then engage the assessment agent for a coverage recommendation.</p>
        </div>
    </div>
</div>

<section class="panel assessment-panel">
    <h2>Try It Out — Claims Assessment Demo</h2>
    <p class="muted assessment-help">
        Pick a Claim Case opened by the
        <a href="/agents/claims-intake">Claims Intake demo</a>, review the
        captured fields, then engage Adam's assessment agent. The agent loads
        the policy wording, lines it up with the incident, and returns a
        coverage recommendation citing the relevant clauses.
    </p>

    <!-- Step 1 — pick a claim -->
    <div class="assessment-step" data-step="1">
        <div class="assessment-step-head">
            <span class="assessment-step-num">1</span>
            <h3>Pick a claim</h3>
        </div>
        <p class="muted">
            Claim cases minted by the Claims Intake "Try It Out" demo are kept
            in memory and surface here.
        </p>
        <div class="assessment-picker">
            <label for="assessment-claim-select" class="assessment-picker-label">Claim number</label>
            <select id="assessment-claim-select" class="assessment-claim-select">
                <option value="">— Loading claims —</option>
            </select>
            <button type="button" id="assessment-refresh-btn" class="assessment-refresh" title="Refresh claim list">↻</button>
        </div>
        <div id="assessment-empty" class="assessment-empty" hidden>
            No claims are in memory yet. Lodge one from the
            <a href="/agents/claims-intake">Claims Intake</a> Try It Out tab,
            then come back.
        </div>
    </div>

    <!-- Step 2 — review the claim case -->
    <div class="assessment-step" data-step="2" id="assessment-claim-card-step" hidden>
        <div class="assessment-step-head">
            <span class="assessment-step-num">2</span>
            <h3>Review the claim case</h3>
        </div>
        <p class="muted">Captured by Iris on intake. Adam's agent will assess this against the policy.</p>
        <div class="assessment-claim-card" id="assessment-claim-card"></div>
    </div>

    <!-- Step 3 — engage the agent -->
    <div class="assessment-step" data-step="3" id="assessment-process-step" hidden>
        <div class="assessment-step-head">
            <span class="assessment-step-num">3</span>
            <h3>Engage Claims Assessment Agent</h3>
        </div>
        <p class="muted">
            The agent pulls the relevant policy wording, compares it against the
            incident and evidence, lists any missing information, and recommends
            approve, partial, or decline.
        </p>
        <button id="assessment-process-btn" type="button">Process with Claims Assessment Agent</button>
        <div id="assessment-process-status" class="assessment-status" hidden></div>
        <div id="assessment-result" class="assessment-result" hidden>
            <div class="assessment-result-head">
                <span class="assessment-result-pill" id="assessment-result-pill"></span>
                <span class="assessment-result-title">Assessment recommendation</span>
            </div>
            <pre id="assessment-result-body"></pre>
        </div>
    </div>
</section>

<style>
    .assessment-panel { --assessment-accent: #6366f1; }
    .assessment-help { margin-bottom: 0.9rem; }
    .assessment-help code { background: rgba(165, 180, 252, 0.14); padding: 1px 6px; border-radius: 4px; font-size: 0.85rem; }

    .assessment-step {
        border: 1px solid rgba(120, 150, 200, 0.18);
        background: rgba(15, 22, 38, 0.4);
        border-radius: 12px;
        padding: 0.95rem 1.1rem 1rem 1.1rem;
        margin-top: 0.9rem;
    }
    .assessment-step-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.3rem; }
    .assessment-step-head h3 { margin: 0; color: #fff; font-size: 1rem; }
    .assessment-step-num {
        display: inline-grid; place-items: center;
        width: 1.55rem; height: 1.55rem;
        border-radius: 50%;
        background: color-mix(in srgb, var(--assessment-accent) 22%, rgba(20, 28, 46, 0.7));
        border: 1px solid color-mix(in srgb, var(--assessment-accent) 55%, transparent);
        color: var(--assessment-accent);
        font-size: 0.78rem; font-weight: 700;
    }
    .assessment-step .muted { color: var(--zava-muted, #97a3b6); font-size: 0.9rem; margin: 0.35rem 0 0.7rem 0; }

    .assessment-picker { display: flex; align-items: center; gap: 0.55rem; flex-wrap: wrap; }
    .assessment-picker-label {
        font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--zava-muted, #97a3b6); font-weight: 700;
    }
    .assessment-claim-select {
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.25);
        color: #fff;
        padding: 0.5rem 0.7rem;
        border-radius: 6px;
        font-size: 0.9rem;
        min-width: 320px;
        font-family: inherit;
    }
    .assessment-claim-select:focus {
        outline: none;
        border-color: var(--assessment-accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--assessment-accent) 25%, transparent);
    }
    .assessment-refresh {
        background: transparent;
        color: rgba(238, 242, 247, 0.86);
        border: 1px solid rgba(120, 150, 200, 0.32);
        border-radius: 6px;
        padding: 0.35rem 0.6rem;
        font-size: 0.95rem;
        cursor: pointer;
    }
    .assessment-refresh:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }

    .assessment-empty {
        margin-top: 0.7rem;
        padding: 0.7rem 0.9rem;
        background: rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.3);
        border-radius: 8px;
        color: #fcd34d;
        font-size: 0.88rem;
    }
    .assessment-empty a { color: #fde68a; }

    .assessment-claim-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.45rem 1.2rem;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 8px;
        padding: 0.85rem 1rem;
        font-size: 0.88rem;
        color: rgba(238, 242, 247, 0.88);
    }
    @@media (max-width: 820px) { .assessment-claim-card { grid-template-columns: 1fr; } }
    .assessment-claim-card .row { display: flex; gap: 0.5rem; }
    .assessment-claim-card .row.span-2 { grid-column: span 2; }
    @@media (max-width: 820px) { .assessment-claim-card .row.span-2 { grid-column: span 1; } }
    .assessment-claim-card .k {
        min-width: 110px;
        color: var(--zava-muted, #97a3b6);
        text-transform: uppercase; font-size: 0.66rem; letter-spacing: 0.08em;
        font-weight: 700;
        padding-top: 0.15rem;
    }
    .assessment-claim-card .v { color: rgba(238, 242, 247, 0.92); }
    .assessment-claim-card .v.mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }
    .assessment-claim-card .urg-pill {
        display: inline-block;
        padding: 0.05rem 0.55rem;
        border-radius: 999px;
        font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
    }
    .assessment-claim-card .urg-pill.high   { background: rgba(239, 68, 68, 0.18); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.4); }
    .assessment-claim-card .urg-pill.medium { background: rgba(245, 158, 11, 0.18); color: #fcd34d; border: 1px solid rgba(245, 158, 11, 0.4); }
    .assessment-claim-card .urg-pill.low    { background: rgba(34, 197, 94, 0.16); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.4); }

    #assessment-process-btn {
        background: var(--assessment-accent);
        color: #0b0f24;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.88rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 0.35rem;
    }
    #assessment-process-btn:disabled { opacity: 0.55; cursor: not-allowed; }

    .assessment-status {
        margin-top: 0.6rem; font-size: 0.88rem;
        color: rgba(238, 242, 247, 0.88);
    }
    .assessment-status.error { color: #fca5a5; }
    .assessment-status .spinner {
        display: inline-block; width: 12px; height: 12px;
        border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
        border-radius: 50%; margin-right: 6px; vertical-align: middle;
        animation: assessment-spin 0.7s linear infinite;
    }
    @@keyframes assessment-spin { to { transform: rotate(360deg); } }

    .assessment-result {
        margin-top: 0.8rem;
        background: color-mix(in srgb, var(--assessment-accent) 8%, rgba(10, 16, 28, 0.7));
        border: 1px solid color-mix(in srgb, var(--assessment-accent) 35%, transparent);
        border-radius: 10px;
        padding: 0.85rem 1rem;
    }
    .assessment-result-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem; }
    .assessment-result-title { color: #fff; font-weight: 700; font-size: 0.92rem; }
    .assessment-result-pill {
        padding: 0.18rem 0.7rem;
        border-radius: 999px;
        font-size: 0.72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.08em;
        background: rgba(165, 180, 252, 0.18);
        color: #c7d2fe;
        border: 1px solid rgba(165, 180, 252, 0.4);
    }
    .assessment-result-pill.approve { background: rgba(34, 197, 94, 0.16); color: #86efac; border-color: rgba(34, 197, 94, 0.4); }
    .assessment-result-pill.partial { background: rgba(245, 158, 11, 0.18); color: #fcd34d; border-color: rgba(245, 158, 11, 0.4); }
    .assessment-result-pill.decline { background: rgba(239, 68, 68, 0.18); color: #fca5a5; border-color: rgba(239, 68, 68, 0.4); }
    .assessment-result-pill.info    { background: rgba(110, 193, 255, 0.14); color: #d6ecff; border-color: rgba(110, 193, 255, 0.35); }
    .assessment-result pre {
        color: rgba(238, 242, 247, 0.9);
        font-size: 0.85rem;
        line-height: 1.55;
        white-space: pre-wrap;
        margin: 0;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }
</style>

<script>
    (function () {
        const root = document.querySelector('.assessment-panel');
        if (!root || root.dataset.wired === '1') return;
        root.dataset.wired = '1';

        const $ = sel => root.querySelector(sel);
        const select = $('#assessment-claim-select');
        const refreshBtn = $('#assessment-refresh-btn');
        const emptyEl = $('#assessment-empty');
        const cardStep = $('#assessment-claim-card-step');
        const card = $('#assessment-claim-card');
        const processStep = $('#assessment-process-step');
        const processBtn = $('#assessment-process-btn');
        const processStatus = $('#assessment-process-status');
        const resultEl = $('#assessment-result');
        const resultBody = $('#assessment-result-body');
        const resultPill = $('#assessment-result-pill');

        let currentClaim = null;

        function escapeHtml(s) {
            return String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
        }

        async function loadClaims() {
            select.innerHTML = '<option value="">— Loading claims —</option>';
            emptyEl.hidden = true;
            try {
                const res = await fetch('/assessment/claims');
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const claims = await res.json();
                if (!claims.length) {
                    select.innerHTML = '<option value="">— No claims in memory —</option>';
                    emptyEl.hidden = false;
                    cardStep.hidden = true;
                    processStep.hidden = true;
                    return;
                }
                select.innerHTML =
                    '<option value="">— Select a claim —</option>' +
                    claims.map(c => `<option value="${escapeHtml(c.claimNumber)}">${escapeHtml(c.claimNumber)} — ${escapeHtml(c.customerName)} (${escapeHtml(c.claimType)})</option>`).join('');
            } catch (err) {
                select.innerHTML = '<option value="">— Failed to load —</option>';
                emptyEl.hidden = false;
                emptyEl.textContent = 'Failed to load claims: ' + err.message;
            }
        }

        async function selectClaim(claimNumber) {
            currentClaim = null;
            resultEl.hidden = true;
            processStatus.hidden = true;
            if (!claimNumber) {
                cardStep.hidden = true;
                processStep.hidden = true;
                return;
            }
            try {
                const res = await fetch(`/assessment/claims/${encodeURIComponent(claimNumber)}`);
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const c = await res.json();
                currentClaim = c;
                renderCard(c);
                cardStep.hidden = false;
                processStep.hidden = false;
                processBtn.disabled = false;
            } catch (err) {
                cardStep.hidden = true;
                processStep.hidden = true;
                emptyEl.hidden = false;
                emptyEl.textContent = 'Failed to load claim: ' + err.message;
            }
        }

        function renderCard(c) {
            const u = (c.urgency || '').toLowerCase();
            const urgClass = u === 'high' || u === 'medium' || u === 'low' ? u : 'medium';
            card.innerHTML = `
                <div class="row"><div class="k">Claim no.</div><div class="v mono">${escapeHtml(c.claimNumber)}</div></div>
                <div class="row"><div class="k">Created</div><div class="v">${escapeHtml((c.createdAt || '').replace('T', ' ').slice(0, 19))}</div></div>
                <div class="row"><div class="k">Customer</div><div class="v">${escapeHtml(c.customerName)}</div></div>
                <div class="row"><div class="k">Policy</div><div class="v mono">${escapeHtml(c.policyNumber)}</div></div>
                <div class="row"><div class="k">Claim type</div><div class="v">${escapeHtml(c.claimType)}</div></div>
                <div class="row"><div class="k">Incident date</div><div class="v">${escapeHtml(c.incidentDate)}</div></div>
                <div class="row span-2"><div class="k">Location</div><div class="v">${escapeHtml(c.incidentLocation)}</div></div>
                <div class="row span-2"><div class="k">Description</div><div class="v">${escapeHtml(c.incidentDescription)}</div></div>
                <div class="row"><div class="k">Estimated loss</div><div class="v">${escapeHtml(c.estimatedLoss)}</div></div>
                <div class="row"><div class="k">Preferred contact</div><div class="v">${escapeHtml(c.preferredContact)}</div></div>
                <div class="row span-2"><div class="k">Intake urgency</div><div class="v"><span class="urg-pill ${urgClass}">${escapeHtml(c.urgency)}</span> &nbsp;${escapeHtml(c.urgencyReason)}</div></div>
            `;
        }

        function classifyRecommendation(text) {
            const t = (text || '').toLowerCase();
            // Look for the "Coverage Recommendation" line and infer the verdict.
            const m = t.match(/coverage recommendation[^\n]*?\n?[^a-z]*([a-z ]+)/);
            const head = (m && m[1]) ? m[1] : t.slice(0, 200);
            if (head.includes('approve') && head.includes('partial')) return { cls: 'partial', label: 'Partial Approve' };
            if (head.includes('partial')) return { cls: 'partial', label: 'Partial Approve' };
            if (head.includes('decline')) return { cls: 'decline', label: 'Decline' };
            if (head.includes('approve')) return { cls: 'approve', label: 'Approve' };
            if (head.includes('more info') || head.includes('need')) return { cls: 'info', label: 'Need More Info' };
            return { cls: 'info', label: 'Recommendation' };
        }

        async function processClaim() {
            if (!currentClaim) return;
            processBtn.disabled = true;
            processStatus.hidden = false;
            processStatus.className = 'assessment-status';
            processStatus.innerHTML = '<span class="spinner"></span>Engaging Claims Assessment Agent…';
            resultEl.hidden = true;

            try {
                const res = await fetch('/assessment/process', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ claimNumber: currentClaim.claimNumber })
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || ('HTTP ' + res.status));

                processStatus.textContent = data.agentConfigured
                    ? 'Claims Assessment Agent reviewed the case against the policy.'
                    : 'Processed (Foundry agent not configured — using deterministic demo summary).';

                const verdict = classifyRecommendation(data.agentNotes);
                resultPill.textContent = verdict.label;
                resultPill.className = 'assessment-result-pill ' + verdict.cls;
                resultBody.textContent = data.agentNotes || '(no output)';
                resultEl.hidden = false;
            } catch (err) {
                processStatus.className = 'assessment-status error';
                processStatus.textContent = 'Failed to process: ' + err.message;
            } finally {
                processBtn.disabled = false;
            }
        }

        select.addEventListener('change', () => selectClaim(select.value));
        refreshBtn.addEventListener('click', loadClaims);
        processBtn.addEventListener('click', processClaim);

        loadClaims();
    })();
</script>
