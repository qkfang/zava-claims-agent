@page "/agents/{Id}"
@inject NavigationManager Nav

@if (AgentModel is null)
{
    <PageTitle>Agent not found — Claims Team in a Day</PageTitle>
    <h1>Agent not found</h1>
    <p>No agent with id <code>@Id</code> exists.</p>
    <a href="/">Back to the claims office</a>
}
else
{
    <PageTitle>@AgentModel.Name — Claims Team in a Day</PageTitle>

    <div class="agent-header" style="--accent: @AgentModel.Accent">
        <a class="back-link" href="/"><span aria-hidden="true">←</span> Back to claims office</a>
        <div class="agent-header-row">
            <div class="agent-header-icon">@AgentModel.Icon</div>
            <div>
                <div class="agent-header-dept">@AgentModel.Department</div>
                <h1>@AgentModel.Name</h1>
                <div class="agent-header-persona">@AgentModel.Persona</div>
                <p class="tagline">@AgentModel.Tagline</p>
            </div>
        </div>
    </div>

    @if (AgentModel.Id == "claims-intake")
    {
        <div class="agent-tabs" role="tablist" aria-label="Claims Intake views">
            <button type="button" class="agent-tab active" role="tab"
                    aria-selected="true" data-tab="overview">Overview</button>
            <button type="button" class="agent-tab" role="tab"
                    aria-selected="false" data-tab="tryit">Try It Out</button>
        </div>
    }

    <div class="agent-tab-panel @(AgentModel.Id == "claims-intake" ? "tab-panel-overview active" : "")"
         data-panel="overview">
        <section class="panel">
        <h2>What this agent does</h2>
        <p>@AgentModel.Purpose</p>
        <div class="two-col">
            <div>
                <h3>Responsibilities</h3>
                <ul>
                    @foreach (var item in AgentModel.Responsibilities)
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
            <div>
                <h3>Tools available</h3>
                <ul>
                    @foreach (var item in AgentModel.Tools)
                    {
                        <li>@item</li>
                    }
                </ul>
                <h3>Human approval</h3>
                <p class="approval">@AgentModel.HumanApproval</p>
            </div>
        </div>
    </section>

    <section class="panel">
        <h2>Demo: how this agent helps with the claim</h2>
        <p class="muted">
            Two demo scenarios are walked through below. These follow scenarios 1 and 2 from
            <code>docs/characters.md</code>. Each scenario shows the trigger that wakes the agent,
            the actions it performs, and the handoff to the next part of the claims office.
        </p>

        @foreach (var scenario in AgentModel.Scenarios)
        {
            <article class="scenario" style="--accent: @AgentModel.Accent">
                <header class="scenario-head">
                    <div class="scenario-num">Scenario @scenario.ScenarioId</div>
                    <h3>@scenario.CustomerName — @scenario.ClaimType</h3>
                </header>

                <div class="scenario-grid">
                    <div class="scenario-card">
                        <div class="scenario-card-label">Situation</div>
                        <p>@scenario.Situation</p>
                        <blockquote>“@scenario.CustomerQuote”</blockquote>
                    </div>
                    <div class="scenario-card">
                        <div class="scenario-card-label">Trigger</div>
                        <p>@scenario.Trigger</p>
                    </div>
                </div>

                <h4>Agent actions</h4>
                <ol class="actions">
                    @foreach (var action in scenario.Actions)
                    {
                        <li>
                            <div class="action-title">@action.Title</div>
                            <div class="action-detail">@action.Detail</div>
                        </li>
                    }
                </ol>

                <div class="handoff">
                    <span class="handoff-label">Handoff →</span> @scenario.Handoff
                </div>
            </article>
        }
    </section>

    <section class="panel">
        <h2>Other agents in the claims office</h2>
        <div class="other-agents">
            @foreach (var other in AgentCatalog.All.Where(a => a.Id != AgentModel.Id))
            {
                <a class="other-agent" href="@($"/agents/{other.Id}")">
                    <span class="other-agent-icon">@other.Icon</span>
                    <span>@other.Name</span>
                </a>
            }
        </div>
    </section>
    </div>

    @if (AgentModel.Id == "claims-intake")
    {
        <div class="agent-tab-panel tab-panel-tryit" data-panel="tryit">
            <ClaimsIntakeDemo />
        </div>
    }
}

<style>
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-bottom: 0.85rem;
        color: var(--zava-muted, #97a3b6);
        text-decoration: none;
        font-size: 0.85rem;
        letter-spacing: 0.2px;
    }
    .back-link:hover {
        color: var(--zava-text-strong, #fff);
        text-decoration: none;
    }

    .agent-header {
        position: relative;
        background: rgba(20, 28, 46, 0.82);
        border: 1px solid rgba(120, 150, 200, 0.22);
        border-radius: 16px;
        padding: 1.4rem 1.6rem 1.5rem 1.6rem;
        margin-bottom: 1.25rem;
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
        overflow: hidden;
    }
    .agent-header::before {
        content: "";
        position: absolute;
        left: 0; top: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 30%, transparent));
    }
    .agent-header::after {
        content: "";
        position: absolute;
        right: -80px; top: -80px;
        width: 260px; height: 260px;
        border-radius: 50%;
        background: radial-gradient(circle, color-mix(in srgb, var(--accent) 18%, transparent) 0%, transparent 65%);
        pointer-events: none;
    }
    .agent-header-row {
        display: flex;
        gap: 1.1rem;
        align-items: flex-start;
        position: relative;
        z-index: 1;
    }
    .agent-header-icon {
        font-size: 1.9rem;
        line-height: 1;
        width: 64px;
        height: 64px;
        border-radius: 14px;
        background: color-mix(in srgb, var(--accent) 20%, rgba(20, 28, 46, 0.6));
        border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
        display: grid;
        place-items: center;
        flex-shrink: 0;
    }
    .agent-header h1 {
        margin: 0.1rem 0 0.2rem 0;
        font-size: 1.7rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: -0.2px;
    }
    .agent-header-dept {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--accent);
    }
    .agent-header-persona {
        color: rgba(214, 228, 245, 0.78);
        font-size: 0.95rem;
    }
    .agent-header .tagline {
        margin: 0.45rem 0 0 0;
        color: rgba(238, 242, 247, 0.85);
        font-style: italic;
        font-size: 0.95rem;
    }

    .panel {
        background: rgba(20, 28, 46, 0.78);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 14px;
        padding: 1.3rem 1.5rem;
        margin-bottom: 1.25rem;
        backdrop-filter: blur(8px);
        box-shadow: 0 6px 22px rgba(0, 0, 0, 0.35);
    }
    .panel h2 {
        margin-top: 0;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--zava-muted, #97a3b6);
        font-weight: 700;
        margin-bottom: 0.85rem;
    }
    .panel h3 {
        font-size: 0.95rem;
        margin: 0 0 0.4rem 0;
        color: #fff;
        font-weight: 600;
    }
    .panel > p { color: rgba(238, 242, 247, 0.86); line-height: 1.55; }
    .panel .muted { color: var(--zava-muted, #97a3b6); font-size: 0.92rem; }
    .panel ul { margin: 0; padding-left: 1.1rem; color: rgba(238, 242, 247, 0.86); }
    .panel ul li { margin-bottom: 0.3rem; line-height: 1.5; }
    .panel ul li::marker { color: var(--accent, #ffb347); }
    .approval {
        color: rgba(238, 242, 247, 0.86);
        background: rgba(110, 193, 255, 0.08);
        border: 1px solid rgba(110, 193, 255, 0.22);
        border-radius: 8px;
        padding: 0.55rem 0.8rem;
        font-size: 0.92rem;
    }

    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.4rem;
        margin-top: 0.5rem;
    }
    @@media (max-width: 720px) { .two-col { grid-template-columns: 1fr; } }

    .scenario {
        position: relative;
        border: 1px solid rgba(120, 150, 200, 0.2);
        border-radius: 12px;
        padding: 1rem 1.15rem 1.1rem 1.15rem;
        margin-top: 1rem;
        background: rgba(15, 22, 38, 0.55);
        overflow: hidden;
    }
    .scenario::before {
        content: "";
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: var(--accent);
    }

    .scenario-head {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .scenario-num {
        background: color-mix(in srgb, var(--accent) 22%, rgba(20, 28, 46, 0.6));
        color: var(--accent);
        border: 1px solid color-mix(in srgb, var(--accent) 50%, transparent);
        padding: 0.18rem 0.7rem;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }
    .scenario h3 {
        margin: 0;
        font-size: 1.05rem;
        color: #fff;
        font-weight: 700;
    }

    .scenario-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 0.75rem;
        margin: 0.85rem 0;
    }
    @@media (max-width: 720px) { .scenario-grid { grid-template-columns: 1fr; } }
    .scenario-card {
        background: rgba(20, 28, 46, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 10px;
        padding: 0.7rem 0.95rem;
    }
    .scenario-card-label {
        font-size: 0.66rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--zava-muted, #97a3b6);
        font-weight: 700;
        margin-bottom: 0.3rem;
    }
    .scenario-card p { margin: 0; font-size: 0.92rem; color: rgba(238, 242, 247, 0.88); line-height: 1.5; }
    .scenario-card blockquote {
        margin: 0.55rem 0 0 0;
        padding: 0.4rem 0.85rem;
        border-left: 3px solid var(--accent);
        background: rgba(255, 179, 71, 0.06);
        border-radius: 0 6px 6px 0;
        color: rgba(238, 242, 247, 0.78);
        font-style: italic;
        font-size: 0.9rem;
    }

    .scenario h4 {
        margin: 1rem 0 0.45rem 0;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--zava-muted, #97a3b6);
        font-weight: 700;
    }
    ol.actions {
        margin: 0;
        padding-left: 0;
        list-style: none;
        counter-reset: action;
    }
    ol.actions li {
        position: relative;
        padding: 0.45rem 0 0.55rem 2.1rem;
        margin-bottom: 0.15rem;
        border-bottom: 1px dashed rgba(120, 150, 200, 0.14);
        counter-increment: action;
    }
    ol.actions li:last-child { border-bottom: none; }
    ol.actions li::before {
        content: counter(action);
        position: absolute;
        left: 0; top: 0.45rem;
        width: 1.6rem; height: 1.6rem;
        background: color-mix(in srgb, var(--accent) 20%, rgba(20, 28, 46, 0.7));
        border: 1px solid color-mix(in srgb, var(--accent) 50%, transparent);
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 700;
        border-radius: 50%;
        display: grid;
        place-items: center;
    }
    .action-title { font-weight: 600; color: #fff; font-size: 0.95rem; }
    .action-detail {
        color: rgba(238, 242, 247, 0.78);
        font-size: 0.9rem;
        line-height: 1.5;
        margin-top: 2px;
    }

    .handoff {
        margin-top: 0.9rem;
        font-size: 0.92rem;
        color: rgba(238, 242, 247, 0.9);
        background: rgba(110, 193, 255, 0.08);
        border: 1px dashed rgba(110, 193, 255, 0.32);
        border-radius: 10px;
        padding: 0.6rem 0.85rem;
    }
    .handoff-label {
        font-weight: 700;
        color: #6ec1ff;
        text-transform: uppercase;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        margin-right: 0.35rem;
    }

    .other-agents {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .other-agent {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.4rem 0.8rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(120, 150, 200, 0.22);
        text-decoration: none;
        color: rgba(238, 242, 247, 0.85);
        font-size: 0.85rem;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }
    .other-agent:hover {
        background: rgba(255, 179, 71, 0.1);
        border-color: rgba(255, 179, 71, 0.4);
        color: #fff;
        text-decoration: none;
    }
    .other-agent-icon { font-size: 1rem; }

    /* Tabs (only used on the Claims Intake agent page) */
    .agent-tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 1px solid rgba(120, 150, 200, 0.22);
        margin-bottom: 1.1rem;
    }
    .agent-tab {
        background: transparent;
        border: none;
        color: rgba(214, 228, 245, 0.7);
        padding: 0.65rem 1.1rem;
        font-size: 0.92rem;
        font-weight: 600;
        letter-spacing: 0.2px;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        transition: color 0.15s ease, border-color 0.15s ease;
    }
    .agent-tab:hover { color: #fff; }
    .agent-tab.active {
        color: #fff;
        border-bottom-color: var(--accent, #ffb347);
    }
    .agent-tab-panel { display: none; }
    .agent-tab-panel.active { display: block; }
    /* When the agent is not claims-intake, the overview panel has no "active"
       class but should still render as the only content on the page. */
    .agent-tab-panel:not(.tab-panel-overview):not(.tab-panel-tryit) { display: block; }
</style>

<script>
    (function () {
        const tabs = document.querySelectorAll('.agent-tabs .agent-tab');
        if (!tabs.length) return;
        const panels = document.querySelectorAll('.agent-tab-panel');
        tabs.forEach(t => t.addEventListener('click', () => {
            const target = t.dataset.tab;
            tabs.forEach(x => {
                const on = x === t;
                x.classList.toggle('active', on);
                x.setAttribute('aria-selected', on ? 'true' : 'false');
            });
            panels.forEach(p => p.classList.toggle('active', p.dataset.panel === target));
        }));
    })();
</script>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private AgentDefinition? AgentModel => AgentCatalog.FindById(Id);
}
