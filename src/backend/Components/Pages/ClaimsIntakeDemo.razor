@*
    Interactive 5-step "Try It Out" demo for the Claims Intake Agent.

    Step 1 — pick one of four sample emails (with a Word claims-form attached).
    Step 2 — engage the Claims Intake Agent (CtAgExtractCU pattern) on the
             email + form text.
    Step 3 — render the mock intake web form, pre-filled with the agent's
             extracted fields.
    Step 4 — show the urgency assessment beside the form.
    Step 5 — submit the form; the backend mints a random claim number that is
             held in memory for the next agent in the demo flow.
*@

<section class="panel intake-panel">
    <h2>Try It Out — Claims Intake Demo</h2>
    <p class="muted intake-help">
        Walk through how Iris's intake agent receives an inbound claim, extracts
        the fields onto the digital intake form, assesses urgency, and opens a
        new Claim Case. All five steps run live against the
        <code>/intake/*</code> endpoints in this app.
    </p>

    <!-- Step 1 — pick a sample email -->
    <div class="intake-step" data-step="1">
        <div class="intake-step-head">
            <span class="intake-step-num">1</span>
            <h3>Pick a sample email</h3>
        </div>
        <p class="muted">Each sample bundles an inbound customer email with a Word claim-form attachment.</p>
        <div class="intake-samples" id="intake-samples"></div>
        <div class="intake-preview" id="intake-preview" hidden>
            <div class="intake-preview-grid">
                <div>
                    <div class="intake-preview-label">Email</div>
                    <div class="intake-preview-meta">
                        <div><span class="k">From</span><span id="intake-email-from"></span></div>
                        <div><span class="k">Date</span><span id="intake-email-date"></span></div>
                        <div><span class="k">Subject</span><span id="intake-email-subject"></span></div>
                    </div>
                    <pre class="intake-preview-body" id="intake-email-body"></pre>
                </div>
                <div>
                    <div class="intake-preview-label">📎 Attachment — <span id="intake-form-name"></span></div>
                    <pre class="intake-preview-body" id="intake-form-body"></pre>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 2 — engage the agent -->
    <div class="intake-step" data-step="2">
        <div class="intake-step-head">
            <span class="intake-step-num">2</span>
            <h3>Engage Claims Intake Agent</h3>
        </div>
        <p class="muted">
            The Claims Intake Agent processes the email + attached form (the same
            <code>CtAgExtractCU</code> pattern used by Notice Intelligence) and
            returns the canonical intake fields plus an urgency call.
        </p>
        <button id="intake-process-btn" type="button" disabled>Process with Claims Intake Agent</button>
        <div id="intake-process-status" class="intake-status" hidden></div>
        <div id="intake-agent-notes" class="intake-notes" hidden>
            <div class="intake-notes-label">Agent narrative</div>
            <pre id="intake-agent-notes-body"></pre>
        </div>
    </div>

    <!-- Step 3 + 4 — mock intake form + urgency assessment -->
    <div class="intake-step" data-step="3">
        <div class="intake-step-head">
            <span class="intake-step-num">3</span>
            <h3>Review the auto-filled intake form</h3>
        </div>
        <p class="muted">
            The agent has mapped each field onto Zava's digital intake form. Every
            field is editable — Iris always confirms before lodging.
        </p>
        <div class="intake-form-wrap" id="intake-form-wrap" hidden>
            <form id="intake-form" class="intake-form" autocomplete="off">
                <div class="intake-grid">
                    <label>Customer name<input name="customerName" required /></label>
                    <label>Customer email<input type="email" name="customerEmail" /></label>
                    <label>Customer phone<input name="customerPhone" /></label>
                    <label>Policy number<input name="policyNumber" required /></label>
                    <label>Claim type<input name="claimType" required /></label>
                    <label>Incident date<input type="text" name="incidentDate" placeholder="YYYY-MM-DD" /></label>
                    <label class="span-2">Incident location<input name="incidentLocation" /></label>
                    <label class="span-2">Incident description<textarea name="incidentDescription" rows="3"></textarea></label>
                    <label>Estimated loss<input name="estimatedLoss" /></label>
                    <label>Preferred contact<input name="preferredContact" /></label>
                </div>

                <!-- Step 4 — urgency callout, rendered next to the form -->
                <div class="intake-urgency" id="intake-urgency" hidden>
                    <div class="intake-urgency-head">
                        <span class="intake-step-num small">4</span>
                        <span class="intake-urgency-title">Urgency assessment</span>
                        <span class="intake-urgency-pill" id="intake-urgency-pill"></span>
                    </div>
                    <p id="intake-urgency-reason"></p>
                </div>

                <div class="intake-form-actions">
                    <button type="submit" id="intake-submit-btn">
                        <span class="intake-step-num inline">5</span>
                        Submit claim
                    </button>
                    <span class="muted intake-submit-hint">Submitting mints a random claim number and hands the case to the Claims Assessment Agent.</span>
                </div>
            </form>
        </div>
    </div>

    <!-- Step 5 — claim number receipt -->
    <div class="intake-step intake-receipt" data-step="5" id="intake-receipt" hidden>
        <div class="intake-step-head">
            <span class="intake-step-num">✓</span>
            <h3>Claim lodged</h3>
        </div>
        <div class="intake-receipt-body">
            <div class="intake-receipt-num" id="intake-receipt-num"></div>
            <p class="muted">
                Held in memory for the rest of the demo. The next agent
                (<a href="/agents/claims-assessment">Claims Assessment</a>) can
                pick the case up by this claim number.
            </p>
            <button type="button" id="intake-reset-btn" class="intake-reset">Run another sample</button>
        </div>
    </div>
</section>

<style>
    .intake-panel { --intake-accent: #0ea5e9; }
    .intake-help { margin-bottom: 0.9rem; }
    .intake-help code { background: rgba(110, 193, 255, 0.12); padding: 1px 6px; border-radius: 4px; font-size: 0.85rem; }

    .intake-step {
        border: 1px solid rgba(120, 150, 200, 0.18);
        background: rgba(15, 22, 38, 0.4);
        border-radius: 12px;
        padding: 0.95rem 1.1rem 1rem 1.1rem;
        margin-top: 0.9rem;
    }
    .intake-step-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.3rem; }
    .intake-step-head h3 { margin: 0; color: #fff; font-size: 1rem; }
    .intake-step-num {
        display: inline-grid; place-items: center;
        width: 1.55rem; height: 1.55rem;
        border-radius: 50%;
        background: color-mix(in srgb, var(--intake-accent) 22%, rgba(20, 28, 46, 0.7));
        border: 1px solid color-mix(in srgb, var(--intake-accent) 55%, transparent);
        color: var(--intake-accent);
        font-size: 0.78rem; font-weight: 700;
    }
    .intake-step-num.small { width: 1.35rem; height: 1.35rem; font-size: 0.7rem; }
    .intake-step-num.inline { margin-right: 0.45rem; vertical-align: middle; }
    .intake-step .muted { color: var(--zava-muted, #97a3b6); font-size: 0.9rem; margin: 0.35rem 0 0.7rem 0; }

    .intake-samples {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 0.6rem;
        margin-top: 0.5rem;
    }
    .intake-sample {
        text-align: left;
        background: rgba(20, 28, 46, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.22);
        border-radius: 10px;
        padding: 0.7rem 0.85rem;
        color: rgba(238, 242, 247, 0.88);
        cursor: pointer;
        transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
    }
    .intake-sample:hover { border-color: color-mix(in srgb, var(--intake-accent) 45%, transparent); background: rgba(24, 34, 56, 0.85); }
    .intake-sample.selected {
        border-color: var(--intake-accent);
        background: color-mix(in srgb, var(--intake-accent) 14%, rgba(20, 28, 46, 0.7));
    }
    .intake-sample-label { font-weight: 700; color: #fff; font-size: 0.92rem; margin-bottom: 0.2rem; }
    .intake-sample-meta { font-size: 0.78rem; color: var(--zava-muted, #97a3b6); }
    .intake-sample-meta .pill {
        display: inline-block;
        background: rgba(110, 193, 255, 0.10);
        border: 1px solid rgba(110, 193, 255, 0.28);
        color: #d6ecff;
        padding: 0.05rem 0.5rem;
        border-radius: 999px;
        font-size: 0.7rem;
        margin-bottom: 0.25rem;
    }

    .intake-preview { margin-top: 0.8rem; }
    .intake-preview-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.7rem;
    }
    @@media (max-width: 820px) { .intake-preview-grid { grid-template-columns: 1fr; } }
    .intake-preview-label {
        font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em;
        color: var(--zava-muted, #97a3b6); font-weight: 700; margin-bottom: 0.3rem;
    }
    .intake-preview-meta { font-size: 0.82rem; color: rgba(238, 242, 247, 0.86); margin-bottom: 0.4rem; }
    .intake-preview-meta div { padding: 0.1rem 0; }
    .intake-preview-meta .k {
        display: inline-block; min-width: 60px;
        color: var(--zava-muted, #97a3b6); font-weight: 600;
        text-transform: uppercase; font-size: 0.66rem; letter-spacing: 0.08em;
        margin-right: 0.5rem;
    }
    .intake-preview-body {
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 8px;
        padding: 0.7rem 0.85rem;
        color: rgba(238, 242, 247, 0.84);
        font-size: 0.82rem;
        line-height: 1.45;
        white-space: pre-wrap;
        max-height: 240px;
        overflow: auto;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    .intake-status {
        margin-top: 0.6rem; font-size: 0.88rem;
        color: rgba(238, 242, 247, 0.88);
    }
    .intake-status.error { color: #fca5a5; }
    .intake-status .spinner {
        display: inline-block; width: 12px; height: 12px;
        border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
        border-radius: 50%; margin-right: 6px; vertical-align: middle;
        animation: intake-spin 0.7s linear infinite;
    }
    @@keyframes intake-spin { to { transform: rotate(360deg); } }

    .intake-notes {
        margin-top: 0.7rem;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.18);
        border-radius: 8px;
        padding: 0.7rem 0.85rem;
    }
    .intake-notes-label {
        font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.12em;
        color: var(--zava-muted, #97a3b6); font-weight: 700; margin-bottom: 0.35rem;
    }
    .intake-notes pre {
        color: rgba(238, 242, 247, 0.86);
        font-size: 0.82rem;
        line-height: 1.5;
        white-space: pre-wrap;
        margin: 0;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    .intake-form-wrap { margin-top: 0.6rem; }
    .intake-form .intake-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.7rem 0.85rem;
    }
    @@media (max-width: 820px) { .intake-form .intake-grid { grid-template-columns: 1fr; } }
    .intake-form .span-2 { grid-column: span 2; }
    @@media (max-width: 820px) { .intake-form .span-2 { grid-column: span 1; } }
    .intake-form label {
        display: block;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--zava-muted, #97a3b6);
        font-weight: 700;
    }
    .intake-form input,
    .intake-form textarea {
        display: block; width: 100%;
        margin-top: 0.3rem;
        background: rgba(10, 16, 28, 0.7);
        border: 1px solid rgba(120, 150, 200, 0.22);
        border-radius: 6px;
        color: #fff;
        font-size: 0.9rem;
        padding: 0.55rem 0.7rem;
        font-family: inherit;
        text-transform: none;
        letter-spacing: normal;
    }
    .intake-form input:focus,
    .intake-form textarea:focus {
        outline: none;
        border-color: var(--intake-accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--intake-accent) 25%, transparent);
    }
    .intake-form textarea { resize: vertical; min-height: 70px; }

    .intake-urgency {
        margin-top: 0.85rem;
        background: color-mix(in srgb, var(--intake-accent) 10%, rgba(15, 22, 38, 0.7));
        border: 1px solid color-mix(in srgb, var(--intake-accent) 35%, transparent);
        border-radius: 10px;
        padding: 0.7rem 0.9rem;
    }
    .intake-urgency-head { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0.25rem; }
    .intake-urgency-title { color: #fff; font-weight: 700; font-size: 0.92rem; }
    .intake-urgency-pill {
        margin-left: auto;
        padding: 0.15rem 0.7rem;
        border-radius: 999px;
        font-size: 0.72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
    }
    .intake-urgency-pill.high   { background: rgba(239, 68, 68, 0.18); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.4); }
    .intake-urgency-pill.medium { background: rgba(245, 158, 11, 0.18); color: #fcd34d; border: 1px solid rgba(245, 158, 11, 0.4); }
    .intake-urgency-pill.low    { background: rgba(34, 197, 94, 0.16); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.4); }
    .intake-urgency p { margin: 0; color: rgba(238, 242, 247, 0.88); font-size: 0.88rem; line-height: 1.45; }

    .intake-form-actions {
        margin-top: 0.95rem;
        display: flex; flex-wrap: wrap; align-items: center; gap: 0.85rem;
    }
    .intake-form-actions button[type=submit] {
        background: var(--intake-accent);
        color: #001624;
        border: none;
        border-radius: 8px;
        padding: 0.55rem 1.1rem;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: filter 0.15s ease, transform 0.15s ease;
    }
    .intake-form-actions button[type=submit]:hover:not(:disabled) { filter: brightness(1.08); transform: translateY(-1px); }
    .intake-form-actions button[type=submit]:disabled { opacity: 0.55; cursor: not-allowed; }
    .intake-submit-hint { font-size: 0.82rem; }

    #intake-process-btn {
        background: var(--intake-accent);
        color: #001624;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.88rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 0.35rem;
    }
    #intake-process-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .intake-receipt { background: rgba(34, 197, 94, 0.08); border-color: rgba(34, 197, 94, 0.35); }
    .intake-receipt-num {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 1.45rem;
        color: #86efac;
        font-weight: 700;
        letter-spacing: 0.5px;
        padding: 0.55rem 0.85rem;
        background: rgba(10, 16, 28, 0.7);
        border: 1px dashed rgba(34, 197, 94, 0.5);
        border-radius: 8px;
        display: inline-block;
        margin: 0.35rem 0 0.65rem 0;
    }
    .intake-reset {
        background: transparent;
        color: rgba(238, 242, 247, 0.86);
        border: 1px solid rgba(120, 150, 200, 0.32);
        border-radius: 6px;
        padding: 0.4rem 0.85rem;
        font-size: 0.85rem;
        cursor: pointer;
    }
    .intake-reset:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }
</style>

<script>
    (function () {
        const root = document.querySelector('.intake-panel');
        if (!root || root.dataset.wired === '1') return;
        root.dataset.wired = '1';

        const $ = sel => root.querySelector(sel);
        const samplesEl = $('#intake-samples');
        const previewEl = $('#intake-preview');
        const processBtn = $('#intake-process-btn');
        const processStatus = $('#intake-process-status');
        const agentNotesEl = $('#intake-agent-notes');
        const agentNotesBody = $('#intake-agent-notes-body');
        const formWrap = $('#intake-form-wrap');
        const form = $('#intake-form');
        const urgencyEl = $('#intake-urgency');
        const urgencyPill = $('#intake-urgency-pill');
        const urgencyReason = $('#intake-urgency-reason');
        const submitBtn = $('#intake-submit-btn');
        const receipt = $('#intake-receipt');
        const receiptNum = $('#intake-receipt-num');
        const resetBtn = $('#intake-reset-btn');

        let selectedSampleId = null;
        let processed = null; // { fields, urgency, urgencyReason }

        function escapeHtml(s) {
            return String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
        }

        async function loadSamples() {
            samplesEl.innerHTML = '<div class="muted">Loading samples…</div>';
            try {
                const res = await fetch('/intake/samples');
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const samples = await res.json();
                samplesEl.innerHTML = samples.map(s => `
                    <button type="button" class="intake-sample" data-id="${escapeHtml(s.id)}">
                        <div class="intake-sample-label">${escapeHtml(s.label)}</div>
                        <div class="intake-sample-meta"><span class="pill">${escapeHtml(s.claimType)}</span></div>
                        <div class="intake-sample-meta">📧 ${escapeHtml(s.emailSubject)}</div>
                        <div class="intake-sample-meta">📎 ${escapeHtml(s.formFileName)}</div>
                    </button>`).join('');
                samplesEl.querySelectorAll('.intake-sample').forEach(el => {
                    el.addEventListener('click', () => selectSample(el.dataset.id));
                });
            } catch (err) {
                samplesEl.innerHTML = `<div class="intake-status error">Failed to load samples: ${escapeHtml(err.message)}</div>`;
            }
        }

        async function selectSample(id) {
            selectedSampleId = id;
            samplesEl.querySelectorAll('.intake-sample').forEach(el => {
                el.classList.toggle('selected', el.dataset.id === id);
            });
            // Reset downstream steps when picking a new sample
            processed = null;
            processStatus.hidden = true;
            agentNotesEl.hidden = true;
            formWrap.hidden = true;
            urgencyEl.hidden = true;
            receipt.hidden = true;

            try {
                const res = await fetch(`/intake/samples/${encodeURIComponent(id)}`);
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const s = await res.json();
                $('#intake-email-from').textContent = s.emailFrom;
                $('#intake-email-date').textContent = s.emailDate;
                $('#intake-email-subject').textContent = s.emailSubject;
                $('#intake-email-body').textContent = s.emailBody;
                $('#intake-form-name').textContent = s.formFileName;
                $('#intake-form-body').textContent = s.formDocumentText;
                previewEl.hidden = false;
                processBtn.disabled = false;
            } catch (err) {
                previewEl.hidden = true;
                processBtn.disabled = true;
                processStatus.hidden = false;
                processStatus.className = 'intake-status error';
                processStatus.textContent = 'Failed to load sample: ' + err.message;
            }
        }

        async function processSample() {
            if (!selectedSampleId) return;
            processBtn.disabled = true;
            processStatus.hidden = false;
            processStatus.className = 'intake-status';
            processStatus.innerHTML = '<span class="spinner"></span>Engaging Claims Intake Agent…';
            agentNotesEl.hidden = true;
            formWrap.hidden = true;
            urgencyEl.hidden = true;
            receipt.hidden = true;

            try {
                const res = await fetch('/intake/process', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sampleId: selectedSampleId })
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || ('HTTP ' + res.status));
                processed = data;

                processStatus.textContent = data.agentConfigured
                    ? 'Claims Intake Agent processed the email and form.'
                    : 'Processed (Foundry agent not configured — using deterministic demo extraction).';
                if (data.agentNotes) {
                    agentNotesEl.hidden = false;
                    agentNotesBody.textContent = data.agentNotes;
                }

                // Step 3 — fill the form
                const f = data.fields || {};
                form.customerName.value         = f.customerName || '';
                form.customerEmail.value        = f.customerEmail || '';
                form.customerPhone.value        = f.customerPhone || '';
                form.policyNumber.value         = f.policyNumber || '';
                form.claimType.value            = f.claimType || '';
                form.incidentDate.value         = f.incidentDate || '';
                form.incidentLocation.value     = f.incidentLocation || '';
                form.incidentDescription.value  = f.incidentDescription || '';
                form.estimatedLoss.value        = f.estimatedLoss || '';
                form.preferredContact.value     = f.preferredContact || '';
                formWrap.hidden = false;

                // Step 4 — urgency
                const level = (data.urgency || 'Medium').toString();
                urgencyPill.textContent = level;
                urgencyPill.className = 'intake-urgency-pill ' + level.toLowerCase();
                urgencyReason.textContent = data.urgencyReason || '';
                urgencyEl.hidden = false;
            } catch (err) {
                processStatus.className = 'intake-status error';
                processStatus.textContent = 'Failed to process: ' + err.message;
                processBtn.disabled = false;
            }
        }

        async function submitForm(ev) {
            ev.preventDefault();
            if (!selectedSampleId || !processed) return;
            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting…';
            try {
                const payload = {
                    sampleId: selectedSampleId,
                    customerName: form.customerName.value,
                    customerEmail: form.customerEmail.value,
                    customerPhone: form.customerPhone.value,
                    policyNumber: form.policyNumber.value,
                    claimType: form.claimType.value,
                    incidentDate: form.incidentDate.value,
                    incidentLocation: form.incidentLocation.value,
                    incidentDescription: form.incidentDescription.value,
                    estimatedLoss: form.estimatedLoss.value,
                    preferredContact: form.preferredContact.value,
                    urgency: processed.urgency,
                    urgencyReason: processed.urgencyReason
                };
                const res = await fetch('/intake/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || ('HTTP ' + res.status));
                receiptNum.textContent = data.claimNumber;
                receipt.hidden = false;
                receipt.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } catch (err) {
                alert('Failed to submit: ' + err.message);
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<span class="intake-step-num inline">5</span>Submit claim';
            }
        }

        function reset() {
            selectedSampleId = null;
            processed = null;
            samplesEl.querySelectorAll('.intake-sample').forEach(el => el.classList.remove('selected'));
            previewEl.hidden = true;
            processBtn.disabled = true;
            processStatus.hidden = true;
            agentNotesEl.hidden = true;
            formWrap.hidden = true;
            urgencyEl.hidden = true;
            receipt.hidden = true;
            form.reset();
            samplesEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        processBtn.addEventListener('click', processSample);
        form.addEventListener('submit', submitForm);
        resetBtn.addEventListener('click', reset);

        loadSamples();
    })();
</script>
