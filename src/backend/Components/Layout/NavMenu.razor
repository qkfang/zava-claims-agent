@* Navigation menu: home + a link to each AI agent and scripted scenario in the claims office. *@
@implements IDisposable
@inject NavigationManager Nav

<div class="brand-row">
    <a class="brand-link" href="">
        <span class="brand-logo" aria-hidden="true">Z</span>
        <span class="brand-text">
            <span class="brand-title">Zava Insurance</span>
            <span class="brand-subtitle">Claims Team in a Day</span>
        </span>
    </a>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon" aria-hidden="true">🏢</span> Claims office
            </NavLink>
        </div>

        @* Native <details>/<summary> gives us click-to-toggle without needing
           InteractiveServer rendering. The `open` attribute is seeded from the
           current route so the user's active section is expanded by default,
           and the browser then handles open/close on click. *@
        <details class="nav-section" open="@IsAgentsOpen">
            <summary class="nav-section-label">AI Agents</summary>
            <div class="nav-section-body">
                @foreach (var agent in AgentCatalog.All)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"agents/{agent.Id}")">
                            <span class="nav-icon" aria-hidden="true">@agent.Icon</span> @agent.Department
                        </NavLink>
                    </div>
                }
            </div>
        </details>

        <details class="nav-section" open="@IsScenariosOpen">
            <summary class="nav-section-label">Scenarios</summary>
            <div class="nav-section-body">
                @foreach (var scenario in ScenarioCatalog.All)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"scenarios/{scenario.Id}")">
                            <span class="nav-icon" aria-hidden="true">@scenario.Icon</span> @scenario.ShortTitle
                        </NavLink>
                    </div>
                }
            </div>
        </details>
    </nav>

    <div class="trust-footer" aria-label="Security and trust">
        <span class="trust-badge" aria-hidden="true">🛡️</span>
        <div class="trust-text">
            <span class="trust-line">Trusted claims operations</span>
            <span class="trust-sub">Human-in-the-loop · Auditable</span>
        </div>
    </div>
</div>

@code {
    private bool IsAgentsOpen { get; set; }
    private bool IsScenariosOpen { get; set; }

    protected override void OnInitialized()
    {
        ApplyRouteDefaults(Nav.Uri);
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ApplyRouteDefaults(e.Location);
        StateHasChanged();
    }

    private void ApplyRouteDefaults(string uri)
    {
        var path = Nav.ToBaseRelativePath(uri).TrimStart('/');
        // Auto-open the section matching the current route so the active item is visible.
        // After the page renders, the user can independently expand/collapse either
        // section via the native <details> click handling.
        if (path.StartsWith("scenarios", StringComparison.OrdinalIgnoreCase))
        {
            IsScenariosOpen = true;
            IsAgentsOpen = false;
        }
        else if (path.StartsWith("agents", StringComparison.OrdinalIgnoreCase))
        {
            IsAgentsOpen = true;
            IsScenariosOpen = false;
        }
        else
        {
            // Default landing: show AI Agents expanded, Scenarios collapsed.
            IsAgentsOpen = true;
            IsScenariosOpen = false;
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
