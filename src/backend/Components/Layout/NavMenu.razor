@* Navigation menu: home + a link to each AI agent and scripted scenario in the claims office. *@
@implements IDisposable
@inject NavigationManager Nav

<div class="brand-row">
    <a class="brand-link" href="">
        <span class="brand-logo" aria-hidden="true">Z</span>
        <span class="brand-text">
            <span class="brand-title">Zava Insurance</span>
            <span class="brand-subtitle">Claims Team in a Day</span>
        </span>
    </a>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon" aria-hidden="true">🏢</span> Claims office
            </NavLink>
        </div>

        <div class="nav-section @(IsAgentsOpen ? "open" : "")">
            <div class="nav-section-label">AI Agents</div>
            <div class="nav-section-body">
                @foreach (var agent in AgentCatalog.All)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"agents/{agent.Id}")">
                            <span class="nav-icon" aria-hidden="true">@agent.Icon</span> @agent.Department
                        </NavLink>
                    </div>
                }
            </div>
        </div>

        <div class="nav-section @(IsScenariosOpen ? "open" : "")">
            <div class="nav-section-label">Scenarios</div>
            <div class="nav-section-body">
                @foreach (var scenario in ScenarioCatalog.All)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"scenarios/{scenario.Id}")">
                            <span class="nav-icon" aria-hidden="true">@scenario.Icon</span> @scenario.ShortTitle
                        </NavLink>
                    </div>
                }
            </div>
        </div>
    </nav>

    <div class="trust-footer" aria-label="Security and trust">
        <span class="trust-badge" aria-hidden="true">🛡️</span>
        <div class="trust-text">
            <span class="trust-line">Trusted claims operations</span>
            <span class="trust-sub">Human-in-the-loop · Auditable</span>
        </div>
    </div>
</div>

@code {
    private bool IsAgentsOpen { get; set; }
    private bool IsScenariosOpen { get; set; }

    protected override void OnInitialized()
    {
        UpdateOpenSections(Nav.Uri);
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateOpenSections(e.Location);
        StateHasChanged();
    }

    private void UpdateOpenSections(string uri)
    {
        var path = Nav.ToBaseRelativePath(uri).TrimStart('/');
        // Only one section is open at a time, mirroring the user's current item.
        // Default: AI Agents open when on the home page or any other route.
        IsScenariosOpen = path.StartsWith("scenarios/", StringComparison.OrdinalIgnoreCase)
            || path.Equals("scenarios", StringComparison.OrdinalIgnoreCase);
        IsAgentsOpen = !IsScenariosOpen;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
